---
import Dashboard from '../../layouts/Dashboard.astro';
import Table from '../../components/Table.astro';
---

<Dashboard title="Directives">
  <form class="filter-form" id="filter">
    <label>
      Status:
      <select name="status">
        <option value="">all</option>
        <option value="pending">pending</option>
        <option value="claimed">claimed</option>
        <option value="running">running</option>
        <option value="complete">complete</option>
        <option value="failed">failed</option>
        <option value="blocked">blocked</option>
      </select>
    </label>
    <label>
      Limit:
      <input name="limit" type="number" min="1" max="100" value="50" style="width: 4rem;" />
    </label>
    <button type="submit">Apply</button>
  </form>

  <p id="error" class="err" hidden></p>
  <p id="directives-count"></p>
  <Table
    id="directives-table"
    columns={[
      { key: 'created', label: 'Created' },
      { key: 'id', label: 'Id' },
      { key: 'source', label: 'Source' },
      { key: 'intent', label: 'Intent' },
      { key: 'status', label: 'Status' },
      { key: 'autonomy', label: 'Autonomy' },
    ]}
    rows={[]}
    loading
  />

  <script>
    import {
      apiFetch,
      captureTokenFromUrl,
      getToken,
      NoTokenError,
      ApiError,
    } from '../../lib/api';

    interface Directive {
      id: string;
      source: string;
      intent: string;
      status: string;
      createdAt: string;
      autonomy: string;
      projectId?: string;
    }
    interface ListResp {
      items: Directive[];
      total: number;
      limit: number;
      offset: number;
    }

    const showError = (message: string): void => {
      const err = document.getElementById('error');
      if (err === null) return;
      err.textContent = message;
      err.hidden = false;
    };

    const renderDirectives = (resp: ListResp): void => {
      const tbody = document.querySelector('#directives-table tbody');
      const countEl = document.getElementById('directives-count');
      if (tbody === null) return;
      if (countEl !== null) {
        countEl.textContent = `${String(resp.items.length)} of ${String(resp.total)} directives`;
      }
      tbody.innerHTML = '';
      if (resp.items.length === 0) {
        const colCount = document.querySelectorAll('#directives-table thead th').length;
        const tr = document.createElement('tr');
        const td = document.createElement('td');
        td.colSpan = colCount;
        td.className = 'empty';
        td.textContent = 'No directives match.';
        tr.appendChild(td);
        tbody.appendChild(tr);
        return;
      }
      for (const d of resp.items) {
        const tr = document.createElement('tr');

        const createdTd = document.createElement('td');
        createdTd.textContent = d.createdAt.slice(0, 19).replace('T', ' ');
        tr.appendChild(createdTd);

        const idTd = document.createElement('td');
        const idA = document.createElement('a');
        idA.href = `/app/directives/detail?id=${encodeURIComponent(d.id)}`;
        idA.className = 'link';
        idA.textContent = d.id.slice(-8);
        idTd.appendChild(idA);
        tr.appendChild(idTd);

        const sourceTd = document.createElement('td');
        sourceTd.textContent = d.source;
        tr.appendChild(sourceTd);

        const intentTd = document.createElement('td');
        intentTd.textContent = d.intent;
        tr.appendChild(intentTd);

        const statusTd = document.createElement('td');
        statusTd.textContent = d.status;
        tr.appendChild(statusTd);

        const autonomyTd = document.createElement('td');
        autonomyTd.textContent = d.autonomy;
        tr.appendChild(autonomyTd);

        tbody.appendChild(tr);
      }
    };

    const mountPath = (): string => {
      const params = new URLSearchParams(window.location.search);
      const status = params.get('status') ?? '';
      const limit = params.get('limit') ?? '50';
      const qs: string[] = [];
      qs.push(`limit=${encodeURIComponent(limit)}`);
      if (status.length > 0) qs.push(`status=${encodeURIComponent(status)}`);
      return `/api/v1/directives?${qs.join('&')}`;
    };

    captureTokenFromUrl();

    if (getToken() === null) {
      showError('No UI token present. Reopen the URL logged by factoryd.');
    } else {
      apiFetch<ListResp>(mountPath())
        .then(renderDirectives)
        .catch((err: unknown) => {
          if (err instanceof NoTokenError) {
            showError(err.message);
          } else if (err instanceof ApiError) {
            showError(`API error ${String(err.status)} (${err.code}): ${err.message}`);
          } else if (err instanceof Error) {
            showError(`Fetch failed: ${err.message}`);
          } else {
            showError('Unknown error');
          }
        });
    }

    const form = document.getElementById('filter') as HTMLFormElement | null;
    if (form !== null) {
      const params = new URLSearchParams(window.location.search);
      const statusSel = form.elements.namedItem('status') as HTMLSelectElement | null;
      const limitInput = form.elements.namedItem('limit') as HTMLInputElement | null;
      if (statusSel !== null) statusSel.value = params.get('status') ?? '';
      if (limitInput !== null) limitInput.value = params.get('limit') ?? '50';
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const sd = new FormData(form);
        const nextParams = new URLSearchParams();
        const st = String(sd.get('status') ?? '');
        const lim = String(sd.get('limit') ?? '50');
        if (st.length > 0) nextParams.set('status', st);
        nextParams.set('limit', lim);
        window.location.search = `?${nextParams.toString()}`;
      });
    }
  </script>
</Dashboard>
