---
import Dashboard from '../../layouts/Dashboard.astro';
---

<Dashboard title="Directive detail">
  <div id="mount">Loading…</div>

  <script>
    import {
      apiFetch,
      apiPost,
      apiStream,
      captureTokenFromUrl,
      fmtUsd,
      NoTokenError,
      ApiError,
      type StreamConnectionState,
    } from '../../lib/api';
    import type { DirectiveStreamEvent } from '@factory5/ipc/sse';

    // Per-page DOM-builder helper. The live-event render path destroys
    // and rebuilds the entire mount on every state change (new SSE
    // event arrives → full re-render of header / tasks / log tail);
    // a wrapper like this collapses ~3 lines per element to one call.
    // Other pages migrated to component-driven structures during 3.4 —
    // this page kept it because <Card>/<Table>/etc. don't model a
    // stateful streaming surface, and the per-page helper is what
    // STATE.md's "or a per-page helper if the page genuinely needs a
    // wrapper" clause exists for.
    function el(
      tag: string,
      attrs: Record<string, string> = {},
      ...children: (string | Node)[]
    ): HTMLElement {
      const e = document.createElement(tag);
      for (const [k, v] of Object.entries(attrs)) {
        e.setAttribute(k, v);
      }
      for (const c of children) {
        e.appendChild(typeof c === 'string' ? document.createTextNode(c) : c);
      }
      return e;
    }

    interface InflightTask {
      id: string;
      title: string;
      agent: string;
      category: string;
      status: string;
      startedAt?: string;
      finishedAt?: string;
    }
    interface PendingQuestion {
      id: string;
      question: string;
    }
    interface Directive {
      id: string;
      source: string;
      principal: string;
      intent: string;
      autonomy: string;
      status: string;
      createdAt: string;
      blockedReason?: string;
    }
    interface Detail {
      directive: Directive;
      timeline: {
        tasks: InflightTask[];
        openQuestions: PendingQuestion[];
        modelUsage: { totalCostUsd: number; callCount: number };
      };
    }

    interface LogLine {
      ts: string;
      level: string;
      component: string;
      msg: string;
    }

    // ----- mount + state ----------------------------------------------------

    captureTokenFromUrl();

    const mountEl = document.getElementById('mount');
    if (mountEl === null) throw new Error('mount missing');
    const mount: HTMLElement = mountEl;
    const id = new URLSearchParams(window.location.search).get('id');
    if (id === null || id.length === 0) {
      mount.textContent = 'Missing ?id=<directiveId> in URL.';
      throw new Error('missing id');
    }
    const directiveId: string = id;

    interface PageState {
      directive: Directive | null;
      tasks: Map<string, InflightTask>;
      openQuestions: PendingQuestion[];
      modelUsage: { totalCostUsd: number; callCount: number };
      logLines: LogLine[];
      connection: StreamConnectionState;
      finalStatus: string | null;
      finalBlockedReason: string | null;
      // Step 3.6 — cancel button state. `cancelInflight` stays true from
      // click until SSE lands `directive.completed` (status flips out of
      // running/pending and the button hides on the next render). On
      // error, it flips back to false so the operator can retry, and
      // `cancelError` carries the message inline.
      cancelInflight: boolean;
      cancelError: string | null;
      // Tier 10 / 10.5 — resume button state, mirrors the cancel UX:
      // `resumeInflight` flips true on click and stays true through the
      // POST; on success the page navigates to the new directive's
      // detail; on error, flips back to false with `resumeError` set.
      resumeInflight: boolean;
      resumeError: string | null;
    }

    const state: PageState = {
      directive: null,
      tasks: new Map(),
      openQuestions: [],
      modelUsage: { totalCostUsd: 0, callCount: 0 },
      logLines: [],
      connection: 'connecting',
      finalStatus: null,
      finalBlockedReason: null,
      cancelInflight: false,
      cancelError: null,
      resumeInflight: false,
      resumeError: null,
    };

    // Auto-scroll-pin tracking for log tail.
    let logTailPaused = false;

    // ----- render helpers ---------------------------------------------------

    function tsLabel(iso: string | undefined): string {
      if (iso === undefined) return '';
      return iso.replace('T', ' ').slice(0, 19);
    }

    function pipLabel(s: StreamConnectionState): string {
      switch (s) {
        case 'connecting':
          return 'Connecting';
        case 'live':
          return 'Live';
        case 'reconnecting':
          return 'Reconnecting';
        case 'polling':
          return 'Polling fallback';
        case 'disconnected':
          return 'Disconnected';
        case 'completed':
          return 'Completed';
      }
    }

    function effectiveStatus(): string {
      if (state.finalStatus !== null) return state.finalStatus;
      return state.directive?.status ?? '…';
    }

    function effectiveBlockedReason(): string | null {
      if (state.finalBlockedReason !== null) return state.finalBlockedReason;
      return state.directive?.blockedReason ?? null;
    }

    function buildHeader(): HTMLElement {
      const dt = state.directive;
      const status = effectiveStatus();
      const intent = dt?.intent ?? directiveId;

      const heading = el('div', { class: 'detail-header' });

      const titleRow = el('div', { class: 'detail-title-row' });
      titleRow.appendChild(el('h3', { class: 'detail-title' }, `${intent} — ${status}`));
      titleRow.appendChild(buildPip());
      const cancelable = status === 'running' || status === 'pending';
      if (cancelable || state.cancelInflight || state.cancelError !== null) {
        titleRow.appendChild(buildCancelControl());
      }
      // Tier 10 — Resume on any terminal status. Mutex with cancel: never
      // both visible (cancelable XOR terminal). We only show Resume on
      // build directives (intent === 'build'); chat directives don't have
      // a useful resume semantic.
      const resumable =
        intent === 'build' &&
        (status === 'failed' || status === 'blocked' || status === 'complete');
      if (resumable || state.resumeInflight || state.resumeError !== null) {
        titleRow.appendChild(buildResumeControl());
      }
      heading.appendChild(titleRow);

      if (state.cancelError !== null) {
        heading.appendChild(el('p', { class: 'err cancel-err' }, state.cancelError));
      }

      if (state.resumeError !== null) {
        heading.appendChild(el('p', { class: 'err resume-err' }, state.resumeError));
      }

      if (dt !== null) {
        heading.appendChild(
          el(
            'p',
            {},
            el('strong', {}, 'Id: '),
            dt.id,
            el('br'),
            el('strong', {}, 'Created: '),
            tsLabel(dt.createdAt),
            el('br'),
            el('strong', {}, 'Source: '),
            `${dt.source} — ${dt.principal}`,
            el('br'),
            el('strong', {}, 'Autonomy: '),
            dt.autonomy,
          ),
        );
      }

      const blocked = effectiveBlockedReason();
      if (blocked !== null) {
        heading.appendChild(el('p', { class: 'err' }, `Blocked: ${blocked}`));
      }

      heading.appendChild(
        el(
          'p',
          {},
          el('strong', {}, 'Spend: '),
          `${fmtUsd(state.modelUsage.totalCostUsd)} across ${String(state.modelUsage.callCount)} calls`,
        ),
      );

      return heading;
    }

    function buildPip(): HTMLElement {
      const pip = el('span', { class: `live-pip live-pip--${state.connection}` });
      pip.appendChild(el('span', { class: 'live-pip-dot' }));
      pip.appendChild(el('span', { class: 'live-pip-label' }, pipLabel(state.connection)));
      return pip;
    }

    function buildCancelControl(): HTMLButtonElement {
      const btnAttrs: Record<string, string> = { class: 'cancel-btn', type: 'button' };
      if (state.cancelInflight) btnAttrs['disabled'] = 'disabled';
      const btn = el(
        'button',
        btnAttrs,
        state.cancelInflight ? 'Cancelling' : 'Cancel build',
      ) as HTMLButtonElement;
      btn.addEventListener('click', () => {
        void cancelDirective();
      });
      return btn;
    }

    function buildResumeControl(): HTMLButtonElement {
      const btnAttrs: Record<string, string> = { class: 'resume-btn', type: 'button' };
      if (state.resumeInflight) btnAttrs['disabled'] = 'disabled';
      const btn = el(
        'button',
        btnAttrs,
        state.resumeInflight ? 'Resuming…' : 'Resume',
      ) as HTMLButtonElement;
      btn.addEventListener('click', () => {
        void resumeDirective();
      });
      return btn;
    }

    interface ResumeResponse {
      directive: { id: string };
    }

    async function resumeDirective(): Promise<void> {
      if (state.resumeInflight) return;
      state.resumeInflight = true;
      state.resumeError = null;
      render();
      try {
        const resp = (await apiPost(
          `/api/v1/directives/${encodeURIComponent(directiveId)}/resume`,
          {},
        )) as ResumeResponse;
        // Success — navigate to the new directive's detail page. The SSE
        // stream over there will pick up the new run's events as they
        // arrive. We don't bother flipping `resumeInflight` back because
        // we're leaving the page.
        window.location.href = `/app/directives/detail?id=${encodeURIComponent(resp.directive.id)}`;
      } catch (err: unknown) {
        let message = 'Resume failed';
        if (err instanceof ApiError) {
          if (err.code === 'DIRECTIVE_NOT_TERMINAL') {
            message = 'Cannot resume — directive is still running. Cancel it first.';
          } else if (err.code === 'PROJECT_NOT_FOUND') {
            message = `Project path missing on disk: ${err.message}`;
          } else if (err.code === 'UI_AUTH_REQUIRED' || err.code === 'UI_DISABLED') {
            message = `Resume rejected by daemon: ${err.code}.`;
          } else {
            message = `Resume failed: ${err.code} (${String(err.status)}) — ${err.message}`;
          }
        } else if (err instanceof NoTokenError) {
          message = err.message;
        } else if (err instanceof Error) {
          message = `Resume failed: ${err.message}`;
        }
        state.resumeError = message;
        state.resumeInflight = false;
        render();
      }
    }

    async function cancelDirective(): Promise<void> {
      if (state.cancelInflight) return;
      state.cancelInflight = true;
      state.cancelError = null;
      render();
      try {
        await apiPost(`/api/v1/directives/${encodeURIComponent(directiveId)}/cancel`, {
          reason: 'cancelled-from-web-ui',
        });
        // Success — leave `cancelInflight=true` so the button stays
        // "Cancelling" until the SSE `directive.completed` event flips
        // `effectiveStatus()` out of running/pending. On the next render
        // after that, `cancelable` is false and the button drops.
      } catch (err: unknown) {
        let message = 'Cancel failed';
        if (err instanceof ApiError) {
          if (err.code === 'ALREADY_TERMINAL') {
            // Race: another cancel landed first (CLI / second tab). The
            // SSE/polling will sync the status pip; clear the in-flight
            // flag so the button drops on next render.
            message = 'Already finished — refresh to see latest status.';
          } else if (err.code === 'UI_AUTH_REQUIRED' || err.code === 'UI_DISABLED') {
            message = `Cancel rejected by daemon: ${err.code}.`;
          } else {
            message = `Cancel failed: ${err.code} (${String(err.status)}) — ${err.message}`;
          }
        } else if (err instanceof NoTokenError) {
          message = err.message;
        } else if (err instanceof Error) {
          message = `Cancel failed: ${err.message}`;
        }
        state.cancelError = message;
        state.cancelInflight = false;
        render();
      }
    }

    function buildOpenQuestions(): HTMLElement {
      const wrap = el('section', {});
      wrap.appendChild(el('h3', {}, `Open questions (${String(state.openQuestions.length)})`));
      if (state.openQuestions.length === 0) {
        wrap.appendChild(el('p', { class: 'empty' }, 'None'));
        return wrap;
      }
      const ul = el('ul', {});
      for (const q of state.openQuestions) {
        ul.appendChild(
          el(
            'li',
            {},
            el(
              'a',
              { href: `/app/questions/detail?id=${encodeURIComponent(q.id)}`, class: 'link' },
              q.question,
            ),
          ),
        );
      }
      wrap.appendChild(ul);
      return wrap;
    }

    function buildTasks(): HTMLElement {
      const wrap = el('section', {});
      const tasks = Array.from(state.tasks.values()).sort((a, b) => {
        const aStart = a.startedAt ?? '';
        const bStart = b.startedAt ?? '';
        return aStart.localeCompare(bStart);
      });
      wrap.appendChild(el('h3', {}, `Tasks (${String(tasks.length)})`));
      if (tasks.length === 0) {
        wrap.appendChild(el('p', { class: 'empty' }, 'None'));
        return wrap;
      }
      const table = el(
        'table',
        {},
        el(
          'thead',
          {},
          el(
            'tr',
            {},
            el('th', {}, 'Id'),
            el('th', {}, 'Title'),
            el('th', {}, 'Agent'),
            el('th', {}, 'Status'),
            el('th', {}, 'Started'),
            el('th', {}, 'Finished'),
          ),
        ),
      );
      const tbody = el('tbody', {});
      for (const t of tasks) {
        tbody.appendChild(
          el(
            'tr',
            {},
            el('td', {}, t.id.slice(-8)),
            el('td', {}, t.title),
            el('td', {}, `${t.agent} (${t.category})`),
            el('td', {}, t.status),
            el('td', {}, tsLabel(t.startedAt)),
            el('td', {}, tsLabel(t.finishedAt)),
          ),
        );
      }
      table.appendChild(tbody);
      wrap.appendChild(table);
      return wrap;
    }

    function buildLogTail(): HTMLElement | null {
      // Only render the panel after the first log line arrives — log.line
      // emission is wired progressively (deferred slice of 3.1); rendering
      // a permanently-empty panel would mislead the operator.
      if (state.logLines.length === 0) return null;
      const wrap = el('section', { class: 'log-tail' });
      const header = el(
        'div',
        { class: 'log-tail-header' },
        el('strong', {}, 'Live log'),
        el('span', { class: 'log-tail-count' }, `${String(state.logLines.length)} lines`),
      );
      const body = el('div', { class: 'log-tail-body' });
      for (const line of state.logLines) {
        body.appendChild(
          el(
            'div',
            { class: 'log-line' },
            el('span', { class: 'log-ts' }, tsLabel(line.ts)),
            el('span', { class: `log-level log-level-${line.level}` }, line.level),
            el(
              'span',
              { class: 'log-component' },
              line.component,
            ),
            el('span', { class: 'log-msg' }, line.msg),
          ),
        );
      }
      const resume = el('button', { class: 'resume-btn', type: 'button' }, 'Resume tailing');
      resume.addEventListener('click', () => {
        logTailPaused = false;
        wrap.classList.remove('paused');
        body.scrollTop = body.scrollHeight;
      });
      wrap.appendChild(header);
      wrap.appendChild(body);
      wrap.appendChild(resume);
      // Track user scroll: pin to bottom by default, pause when user scrolls up.
      body.addEventListener('scroll', () => {
        const atBottom = body.scrollHeight - body.scrollTop - body.clientHeight < 4;
        if (atBottom) {
          logTailPaused = false;
          wrap.classList.remove('paused');
        } else {
          logTailPaused = true;
          wrap.classList.add('paused');
        }
      });
      // Apply initial pin / pause state after the panel is in the DOM.
      queueMicrotask(() => {
        if (!logTailPaused) {
          body.scrollTop = body.scrollHeight;
        } else {
          wrap.classList.add('paused');
        }
      });
      return wrap;
    }

    function render(): void {
      mount.innerHTML = '';
      mount.appendChild(buildHeader());
      mount.appendChild(buildOpenQuestions());
      mount.appendChild(buildTasks());
      const tail = buildLogTail();
      if (tail !== null) mount.appendChild(tail);
    }

    // ----- snapshot apply (initial fetch + polling fallback) ----------------

    function applySnapshot(detail: Detail): void {
      state.directive = detail.directive;
      // Merge existing live-event state with the snapshot — live events are
      // authoritative for tasks they have already touched (start/end times),
      // so prefer the existing Map entry when present and only insert from
      // the snapshot when missing. This avoids overwriting a finer-grained
      // `task.completed` state with a stale `running` snapshot row from a
      // brief polling-fallback window.
      for (const t of detail.timeline.tasks) {
        if (!state.tasks.has(t.id)) {
          state.tasks.set(t.id, t);
        }
      }
      state.openQuestions = detail.timeline.openQuestions;
      state.modelUsage = detail.timeline.modelUsage;
      // Snapshot has no log tail data — leave state.logLines untouched.
    }

    // ----- live event apply --------------------------------------------------

    function applyEvent(ev: DirectiveStreamEvent): void {
      switch (ev.type) {
        case 'task.started': {
          const existing = state.tasks.get(ev.taskId);
          state.tasks.set(ev.taskId, {
            id: ev.taskId,
            title: ev.title,
            agent: ev.agent,
            category: ev.category,
            status: existing?.status ?? 'running',
            startedAt: ev.startedAt,
            ...(existing?.finishedAt !== undefined ? { finishedAt: existing.finishedAt } : {}),
          });
          break;
        }
        case 'task.completed': {
          const existing = state.tasks.get(ev.taskId);
          if (existing === undefined) {
            // Live-only task we never saw start (rare; race window). Insert
            // a partial row so the table reflects its terminal state.
            state.tasks.set(ev.taskId, {
              id: ev.taskId,
              title: '',
              agent: '',
              category: '',
              status: ev.status,
              finishedAt: ev.finishedAt,
            });
          } else {
            state.tasks.set(ev.taskId, {
              ...existing,
              status: ev.status,
              finishedAt: ev.finishedAt,
            });
          }
          break;
        }
        case 'finding.created': {
          // Wired but emission deferred — re-render is the only effect today.
          // 3.x will surface findings inline on the page.
          break;
        }
        case 'spend.updated': {
          state.modelUsage = {
            totalCostUsd: ev.totalCostUsd,
            callCount: ev.callCount,
          };
          break;
        }
        case 'log.line': {
          state.logLines.push({
            ts: ev.ts,
            level: ev.level,
            component: ev.component,
            msg: ev.msg,
          });
          // Cap memory: keep the last 500 lines.
          if (state.logLines.length > 500) {
            state.logLines.splice(0, state.logLines.length - 500);
          }
          break;
        }
        case 'directive.completed': {
          state.finalStatus = ev.status;
          state.finalBlockedReason = ev.blockedReason;
          break;
        }
      }
    }

    // ----- bootstrap ---------------------------------------------------------

    async function pollOnce(): Promise<void> {
      try {
        const detail = await apiFetch<Detail>(
          `/api/v1/directives/${encodeURIComponent(directiveId)}`,
        );
        applySnapshot(detail);
        // Synthesize a directive.completed-equivalent state if the snapshot
        // shows a terminal directive — keeps the page consistent if the
        // EventSource was lost before directive.completed could land.
        if (
          state.finalStatus === null &&
          (detail.directive.status === 'complete' ||
            detail.directive.status === 'failed' ||
            detail.directive.status === 'blocked')
        ) {
          state.finalStatus = detail.directive.status;
          state.finalBlockedReason = detail.directive.blockedReason ?? null;
        }
        render();
      } catch (err: unknown) {
        // Surface only if the page hasn't rendered yet; otherwise keep the
        // last-good DOM and let the next poll succeed.
        if (state.directive === null) {
          showFatalError(err);
        }
      }
    }

    function showFatalError(err: unknown): void {
      mount.innerHTML = '';
      if (err instanceof NoTokenError) {
        mount.textContent = err.message;
      } else if (err instanceof ApiError) {
        const pre = document.createElement('pre');
        pre.className = 'err';
        pre.textContent = `API error ${String(err.status)} (${err.code}): ${err.message}`;
        mount.appendChild(pre);
      } else if (err instanceof Error) {
        mount.textContent = `Fetch failed: ${err.message}`;
      } else {
        mount.textContent = 'Unknown error';
      }
    }

    async function bootstrap(): Promise<void> {
      // 1. Initial snapshot for static directive metadata + non-streamed
      //    fields (open questions, existing tasks). The SSE backfill on
      //    connect repeats task.* and spend events — applySnapshot's
      //    merge-don't-clobber rule keeps us coherent.
      try {
        const initial = await apiFetch<Detail>(
          `/api/v1/directives/${encodeURIComponent(directiveId)}`,
        );
        applySnapshot(initial);
        render();
      } catch (err: unknown) {
        showFatalError(err);
        return;
      }

      // 2. Subscribe to the live stream. apiStream handles token-auth,
      //    Zod validation, reconnect, and degrades to pollOnce() every
      //    5 s if the EventSource gives up retrying.
      apiStream(`/api/v1/directives/${encodeURIComponent(directiveId)}/stream`, {
        onEvent: (ev) => {
          applyEvent(ev);
          render();
          // After re-render, keep log tail pinned to bottom unless user paused.
          const body = mount.querySelector<HTMLElement>('.log-tail-body');
          if (body !== null && !logTailPaused) {
            body.scrollTop = body.scrollHeight;
          }
        },
        onConnectionState: (next) => {
          state.connection = next;
          // Light-touch re-render: only the pip changes — but the pip lives
          // in the header, so a full render is cheaper than a targeted DOM
          // poke and stays consistent with the rest of the page state.
          render();
        },
        onParseError: (raw, err) => {
          // Non-fatal — log to console for debugging; the page keeps
          // running on previously-applied state.
          console.warn('[stream] parse error', { raw, err });
        },
        pollingFallback: pollOnce,
      });
    }

    void bootstrap();
  </script>

  <style>
    .detail-header {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      margin-bottom: 1rem;
    }
    .detail-title-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .detail-title {
      margin: 0;
    }

    .live-pip {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.2rem 0.6rem;
      border-radius: 999px;
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      border: 1px solid color-mix(in srgb, currentColor 18%, transparent);
      background: color-mix(in srgb, currentColor 4%, transparent);
      line-height: 1;
    }

    /* Cancel button — sits in the title row alongside the live pip.
       Pill geometry mirrors `.live-pip` so the affordance reads as part
       of the same family (live-state + operator-action), but fills out
       a touch more weight and a destructive-warm palette. The blinking
       trailing dot in the disabled state echoes `live-pip-blink` so the
       in-flight visual language is consistent across the header. */
    .cancel-btn {
      font: inherit;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.3rem 0.85rem;
      border-radius: 999px;
      border: 1px solid color-mix(in srgb, #c24 55%, transparent);
      color: #c24;
      background: color-mix(in srgb, #c24 5%, transparent);
      cursor: pointer;
      line-height: 1;
      transition:
        background 0.15s ease,
        border-color 0.15s ease,
        color 0.15s ease;
    }
    .cancel-btn:hover:not(:disabled) {
      background: color-mix(in srgb, #c24 14%, transparent);
      border-color: color-mix(in srgb, #c24 80%, transparent);
    }
    .cancel-btn:focus-visible {
      outline: 2px solid color-mix(in srgb, #c24 60%, transparent);
      outline-offset: 2px;
    }
    .cancel-btn:disabled {
      cursor: progress;
      color: color-mix(in srgb, #c24 55%, transparent);
      border-color: color-mix(in srgb, #c24 28%, transparent);
      background: color-mix(in srgb, #c24 3%, transparent);
    }
    .cancel-btn:disabled::after {
      content: '';
      display: inline-block;
      width: 0.4rem;
      height: 0.4rem;
      border-radius: 50%;
      background: currentColor;
      margin-left: 0.5rem;
      vertical-align: middle;
      animation: live-pip-blink 0.9s ease-in-out infinite;
    }
    .cancel-err {
      margin: 0;
      font-size: 0.75rem;
    }
    /* Resume button base styling lives in Dashboard.astro's global block
       (Tier 10 / 10.5) — scoped <style> rules don't reach JS-created
       elements (no data-astro-cid attribute on runtime <button>s). The
       error-line styling stays local. */
    .resume-err {
