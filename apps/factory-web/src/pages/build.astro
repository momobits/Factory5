---
import Dashboard from '../layouts/Dashboard.astro';
---

<Dashboard title="New build">
  <div id="mount">Loading…</div>

  <script>
    import {
      ApiError,
      NoTokenError,
      apiFetch,
      apiPost,
      captureTokenFromUrl,
      el,
      getToken,
    } from '../lib/api';

    interface Project {
      id: string;
      name: string;
      workspacePath: string;
      lastTouchedAt: string;
      status: string;
    }
    interface ProjectsList {
      items: Project[];
    }
    interface CreateBuildResp {
      directive: { id: string };
    }

    captureTokenFromUrl();

    const mount = document.getElementById('mount');
    if (mount === null) throw new Error('mount missing');

    if (getToken() === null) {
      mount.textContent = 'No UI token present. Reopen the URL logged by factoryd.';
    } else {
      apiFetch<ProjectsList>('/api/v1/projects')
        .then((projects) => renderForm(projects.items, mount))
        .catch((err: unknown) => renderTopError(err, mount));
    }

    function renderForm(projects: Project[], host: HTMLElement): void {
      host.innerHTML = '';

      if (projects.length === 0) {
        const alert = el('div', { class: 'alert alert--info' });
        alert.appendChild(el('h4', {}, 'No projects yet'));
        const p = el('p', {});
        p.appendChild(document.createTextNode('Run '));
        p.appendChild(el('code', {}, 'factory init'));
        p.appendChild(
          document.createTextNode(
            ' in a workspace before kicking off a build — the UI does not create projects from scratch.',
          ),
        );
        alert.appendChild(p);
        host.appendChild(alert);
        return;
      }

      const intro = el('p', {
        style:
          'color: color-mix(in srgb, currentColor 65%, transparent); font-size: 0.9rem; margin: 0 0 1rem 0; max-width: 36rem;',
      });
      intro.appendChild(document.createTextNode('Mints a new directive on the server. Mirrors '));
      intro.appendChild(el('code', {}, 'factory build <project>'));
      intro.appendChild(
        document.createTextNode(
          '. Submit is non-idempotent — the button disables on first click to prevent double-submission.',
        ),
      );
      host.appendChild(intro);

      const form = el('form', { class: 'form' }) as HTMLFormElement;

      const projField = el('div', { class: 'form-field' });
      projField.appendChild(el('label', { for: 'project' }, 'Project'));
      const projSelect = el('select', {
        id: 'project',
        name: 'project',
        required: '',
      }) as HTMLSelectElement;
      for (const p of projects) {
        const opt = el('option', { value: p.name }, p.name) as HTMLOptionElement;
        projSelect.appendChild(opt);
      }
      projField.appendChild(projSelect);
      const projHint = el('div', { class: 'hint' });
      projHint.appendChild(
        document.createTextNode(
          `${String(projects.length)} known project${projects.length === 1 ? '' : 's'} — most-recently touched first. Names are resolved against the daemon's default workspace.`,
        ),
      );
      projField.appendChild(projHint);
      form.appendChild(projField);

      const row = el('div', { class: 'form-row' });

      const langField = el('div', { class: 'form-field' });
      langField.appendChild(el('label', { for: 'language' }, 'Language'));
      const langSelect = el('select', {
        id: 'language',
        name: 'language',
      }) as HTMLSelectElement;
      langSelect.appendChild(el('option', { value: '' }, '(use project default)'));
      for (const lang of ['python', 'node', 'go', 'rust']) {
        langSelect.appendChild(el('option', { value: lang }, lang));
      }
      langField.appendChild(langSelect);
      langField.appendChild(
        el('div', { class: 'hint' }, 'Falls back to project.json metadata.language.'),
      );
      row.appendChild(langField);

      const autoField = el('div', { class: 'form-field' });
      autoField.appendChild(el('label', { for: 'autonomy' }, 'Autonomy'));
      const autoSelect = el('select', {
        id: 'autonomy',
        name: 'autonomy',
      }) as HTMLSelectElement;
      autoSelect.appendChild(el('option', { value: '' }, '(server default — assisted)'));
      for (const a of ['chat', 'assisted', 'autonomous']) {
        autoSelect.appendChild(el('option', { value: a }, a));
      }
      autoField.appendChild(autoSelect);
      row.appendChild(autoField);
      form.appendChild(row);

      const budgetRow = el('div', { class: 'form-row' });

      const usdField = el('div', { class: 'form-field' });
      usdField.appendChild(el('label', { for: 'maxUsd' }, 'Max USD'));
      const usdInput = el('input', {
        id: 'maxUsd',
        name: 'maxUsd',
        type: 'number',
        step: '0.01',
        min: '0',
        placeholder: 'project / config default',
      }) as HTMLInputElement;
      usdField.appendChild(usdInput);
      usdField.appendChild(el('div', { class: 'hint' }, 'Leave blank for default tiers.'));
      budgetRow.appendChild(usdField);

      const stepsField = el('div', { class: 'form-field' });
      stepsField.appendChild(el('label', { for: 'maxSteps' }, 'Max steps'));
      const stepsInput = el('input', {
        id: 'maxSteps',
        name: 'maxSteps',
        type: 'number',
        step: '1',
        min: '1',
        placeholder: 'project / config default',
      }) as HTMLInputElement;
      stepsField.appendChild(stepsInput);
      stepsField.appendChild(el('div', { class: 'hint' }, 'Leave blank for default tiers.'));
      budgetRow.appendChild(stepsField);
      form.appendChild(budgetRow);

      const errSlot = el('div', { id: 'errSlot' });
      form.appendChild(errSlot);

      const actions = el('div', { class: 'form-actions' });
      const submit = el(
        'button',
        { type: 'submit', class: 'btn btn-primary' },
        'Kick off build',
      ) as HTMLButtonElement;
      actions.appendChild(submit);
      form.appendChild(actions);

      host.appendChild(form);

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        if (submit.disabled) return;
        submit.disabled = true;
        submit.textContent = 'Submitting…';
        errSlot.innerHTML = '';

        const body: Record<string, unknown> = { project: projSelect.value };
        if (langSelect.value !== '') body.language = langSelect.value;
        if (autoSelect.value !== '') body.autonomy = autoSelect.value;
        const limits: Record<string, number> = {};
        if (usdInput.value.trim() !== '') {
          const v = Number.parseFloat(usdInput.value);
          if (Number.isFinite(v)) limits.maxUsd = v;
        }
        if (stepsInput.value.trim() !== '') {
          const v = Number.parseInt(stepsInput.value, 10);
          if (Number.isFinite(v)) limits.maxSteps = v;
        }
        if (Object.keys(limits).length > 0) body.limits = limits;

        apiPost<typeof body, CreateBuildResp>('/api/v1/builds', body)
          .then((resp) => {
            window.location.assign(
              `/app/directives/detail?id=${encodeURIComponent(resp.directive.id)}`,
            );
          })
          .catch((err: unknown) => {
            submit.disabled = false;
            submit.textContent = 'Kick off build';
            renderInlineError(err, errSlot);
          });
      });
    }

    function renderInlineError(err: unknown, slot: HTMLElement): void {
      slot.innerHTML = '';
      const alert = el('div', { class: 'alert alert--conflict' });
      if (err instanceof ApiError) {
        alert.appendChild(el('h4', {}, codeHeading(err.code, err.status)));
        alert.appendChild(el('p', {}, err.message));
      } else if (err instanceof Error) {
        alert.appendChild(el('h4', {}, 'Submit failed'));
        alert.appendChild(el('p', {}, err.message));
      } else {
        alert.appendChild(el('h4', {}, 'Submit failed'));
        alert.appendChild(el('p', {}, 'Unknown error.'));
      }
      slot.appendChild(alert);
    }

    function renderTopError(err: unknown, host: HTMLElement): void {
      host.innerHTML = '';
      if (err instanceof NoTokenError) {
        host.textContent = err.message;
        return;
      }
      const alert = el('div', { class: 'alert alert--conflict' });
      if (err instanceof ApiError) {
        alert.appendChild(el('h4', {}, codeHeading(err.code, err.status)));
        alert.appendChild(el('p', {}, err.message));
      } else if (err instanceof Error) {
        alert.appendChild(el('h4', {}, 'Failed to load projects'));
        alert.appendChild(el('p', {}, err.message));
      } else {
        alert.appendChild(el('h4', {}, 'Failed to load projects'));
        alert.appendChild(el('p', {}, 'Unknown error.'));
      }
      host.appendChild(alert);
    }

    function codeHeading(code: string, status: number): string {
      switch (code) {
        case 'PROJECT_NOT_FOUND':
          return 'Project not found — run `factory init` to register one.';
        case 'PROJECT_METADATA_CORRUPT':
          return 'project.json is corrupt — fix it before kicking off a build.';
        case 'PROJECT_PATH_UNREADABLE':
          return 'Project workspace is no longer readable.';
        case 'SCHEMA_VALIDATION_FAILED':
          return 'Validation failed — check the field values.';
        case 'UI_AUTH_REQUIRED':
          return 'Auth token missing or invalid — reopen the URL logged by factoryd.';
        case 'UI_DISABLED':
          return 'Web UI is disabled on this daemon (no FACTORY5_UI_TOKEN).';
        case 'NON_LOCALHOST':
          return 'Request rejected as non-localhost.';
        case 'BAD_REQUEST':
          return 'Bad request.';
        case 'INTERNAL':
          return 'Internal server error.';
        default:
          return `Error ${String(status)} (${code})`;
      }
    }
  </script>
</Dashboard>
