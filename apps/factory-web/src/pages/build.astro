---
import Dashboard from '../layouts/Dashboard.astro';
import Form from '../components/Form.astro';
import Field from '../components/Field.astro';
import Submit from '../components/Submit.astro';
import Alert from '../components/Alert.astro';
---

<Dashboard title="New build">
  <div id="topErrorSlot" hidden>
    <Alert kind="conflict" title="" body="" />
  </div>

  <div id="empty-projects" hidden>
    <Alert kind="info" title="No projects yet">
      <p>
        Run <code>factory init</code> in a workspace before kicking off a build — the UI does
        not create projects from scratch.
      </p>
    </Alert>
  </div>

  <p id="loading" style="color: color-mix(in srgb, currentColor 65%, transparent);">Loading…</p>

  <div id="content" hidden>
    <p
      style="color: color-mix(in srgb, currentColor 65%, transparent); font-size: 0.9rem; margin: 0 0 1rem 0; max-width: 36rem;"
    >
      Mints a new directive on the server. Mirrors <code>factory build &lt;project&gt;</code>.
      Submit is non-idempotent — the button disables on first click to prevent
      double-submission.
    </p>

    <Form id="build-form">
      <Field
        name="project"
        label="Project"
        type="select"
        required
        options={[]}
        hint="Loading projects…"
      />
      <div class="form-row">
        <Field
          name="language"
          label="Language"
          type="select"
          options={[
            { value: '', label: '(use project default)' },
            { value: 'python', label: 'python' },
            { value: 'node', label: 'node' },
            { value: 'go', label: 'go' },
            { value: 'rust', label: 'rust' },
          ]}
          hint="Falls back to project.json metadata.language."
        />
        <Field
          name="autonomy"
          label="Autonomy"
          type="select"
          options={[
            { value: '', label: '(server default — assisted)' },
            { value: 'chat', label: 'chat' },
            { value: 'assisted', label: 'assisted' },
            { value: 'autonomous', label: 'autonomous' },
          ]}
        />
      </div>
      <div class="form-row">
        <Field
          name="maxUsd"
          label="Max USD"
          type="number"
          step="0.01"
          min="0"
          placeholder="project / config default"
          hint="Leave blank for default tiers."
        />
        <Field
          name="maxSteps"
          label="Max steps"
          type="number"
          step="1"
          min="1"
          placeholder="project / config default"
          hint="Leave blank for default tiers."
        />
      </div>

      <div id="form-error-slot" hidden>
        <Alert kind="conflict" title="" body="" />
      </div>

      <div class="form-actions">
        <Submit label="Kick off build" id="submit-btn" />
      </div>
    </Form>
  </div>

  <script>
    import {
      ApiError,
      NoTokenError,
      apiFetch,
      apiPost,
      captureTokenFromUrl,
      getToken,
    } from '../lib/api';

    interface Project {
      id: string;
      name: string;
      workspacePath: string;
      lastTouchedAt: string;
      status: string;
    }
    interface ProjectsList {
      items: Project[];
    }
    interface CreateBuildResp {
      directive: { id: string };
    }

    const setAlertText = (slotId: string, title: string, body: string): void => {
      const slot = document.getElementById(slotId);
      if (slot === null) return;
      const titleEl = slot.querySelector('h4');
      const bodyEl = slot.querySelector('p');
      if (titleEl !== null) titleEl.textContent = title;
      if (bodyEl !== null) bodyEl.textContent = body;
      slot.hidden = false;
    };

    const hideAlert = (slotId: string): void => {
      const slot = document.getElementById(slotId);
      if (slot !== null) slot.hidden = true;
    };

    const codeHeading = (code: string, status: number): string => {
      switch (code) {
        case 'PROJECT_NOT_FOUND':
          return 'Project not found — run `factory init` to register one.';
        case 'PROJECT_METADATA_CORRUPT':
          return 'project.json is corrupt — fix it before kicking off a build.';
        case 'PROJECT_PATH_UNREADABLE':
          return 'Project workspace is no longer readable.';
        case 'SCHEMA_VALIDATION_FAILED':
          return 'Validation failed — check the field values.';
        case 'UI_AUTH_REQUIRED':
          return 'Auth token missing or invalid — reopen the URL logged by factoryd.';
        case 'UI_DISABLED':
          return 'Web UI is disabled on this daemon (no FACTORY5_UI_TOKEN).';
        case 'NON_LOCALHOST':
          return 'Request rejected as non-localhost.';
        case 'BAD_REQUEST':
          return 'Bad request.';
        case 'INTERNAL':
          return 'Internal server error.';
        default:
          return `Error ${String(status)} (${code})`;
      }
    };

    const renderError = (err: unknown, slotId: string, fallbackTitle: string): void => {
      if (err instanceof ApiError) {
        setAlertText(slotId, codeHeading(err.code, err.status), err.message);
      } else if (err instanceof Error) {
        setAlertText(slotId, fallbackTitle, err.message);
      } else {
        setAlertText(slotId, fallbackTitle, 'Unknown error.');
      }
    };

    const populateProjects = (projects: Project[]): void => {
      const projInput = document.getElementById('project') as HTMLSelectElement | null;
      if (projInput === null) return;
      for (const p of projects) {
        const opt = document.createElement('option');
        opt.value = p.name;
        opt.textContent = p.name;
        projInput.appendChild(opt);
      }
      const formField = projInput.parentElement;
      const hintEl = formField?.querySelector('.hint');
      if (hintEl !== null && hintEl !== undefined) {
        const plural = projects.length === 1 ? '' : 's';
        hintEl.textContent = `${String(projects.length)} known project${plural} — most-recently touched first. Names are resolved against the daemon's default workspace.`;
      }
    };

    const wireForm = (): void => {
      const form = document.getElementById('build-form') as HTMLFormElement | null;
      const submit = document.getElementById('submit-btn') as HTMLButtonElement | null;
      if (form === null || submit === null) return;

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        if (submit.disabled) return;
        submit.disabled = true;
        submit.textContent = 'Submitting…';
        hideAlert('form-error-slot');

        const projSelect = document.getElementById('project') as HTMLSelectElement;
        const langSelect = document.getElementById('language') as HTMLSelectElement;
        const autoSelect = document.getElementById('autonomy') as HTMLSelectElement;
        const usdInput = document.getElementById('maxUsd') as HTMLInputElement;
        const stepsInput = document.getElementById('maxSteps') as HTMLInputElement;

        const body: Record<string, unknown> = { project: projSelect.value };
        if (langSelect.value !== '') body.language = langSelect.value;
        if (autoSelect.value !== '') body.autonomy = autoSelect.value;
        const limits: Record<string, number> = {};
        if (usdInput.value.trim() !== '') {
          const v = Number.parseFloat(usdInput.value);
          if (Number.isFinite(v)) limits.maxUsd = v;
        }
        if (stepsInput.value.trim() !== '') {
          const v = Number.parseInt(stepsInput.value, 10);
          if (Number.isFinite(v)) limits.maxSteps = v;
        }
        if (Object.keys(limits).length > 0) body.limits = limits;

        apiPost<typeof body, CreateBuildResp>('/api/v1/builds', body)
          .then((resp) => {
            window.location.assign(
              `/app/directives/detail?id=${encodeURIComponent(resp.directive.id)}`,
            );
          })
          .catch((err: unknown) => {
            submit.disabled = false;
            submit.textContent = 'Kick off build';
            renderError(err, 'form-error-slot', 'Submit failed');
          });
      });
    };

    captureTokenFromUrl();

    if (getToken() === null) {
      const loading = document.getElementById('loading');
      if (loading !== null) {
        loading.textContent = 'No UI token present. Reopen the URL logged by factoryd.';
      }
    } else {
      apiFetch<ProjectsList>('/api/v1/projects')
        .then((projects) => {
          const loading = document.getElementById('loading');
          if (loading !== null) loading.hidden = true;

          if (projects.items.length === 0) {
            const empty = document.getElementById('empty-projects');
            if (empty !== null) empty.hidden = false;
            return;
          }

          const content = document.getElementById('content');
          if (content !== null) content.hidden = false;
          populateProjects(projects.items);
          wireForm();
        })
        .catch((err: unknown) => {
          const loading = document.getElementById('loading');
          if (err instanceof NoTokenError) {
            if (loading !== null) loading.textContent = err.message;
            return;
          }
          if (loading !== null) loading.hidden = true;
          renderError(err, 'topErrorSlot', 'Failed to load projects');
        });
    }
  </script>
</Dashboard>
