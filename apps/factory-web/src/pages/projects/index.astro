---
import Dashboard from '../../layouts/Dashboard.astro';
import Table from '../../components/Table.astro';
import Alert from '../../components/Alert.astro';
---

<Dashboard title="Projects">
  <p style="margin: 0 0 1rem 0;">
    <a
      href="/app/projects/new"
      style="color: inherit; font-weight: 600; text-decoration: none; border: 1px solid color-mix(in srgb, currentColor 25%, transparent); padding: 0.35rem 0.85rem; border-radius: 4px; font-size: 0.9rem; display: inline-block;"
    >
      + New project
    </a>
  </p>

  <p id="error" class="err" hidden></p>

  <div id="empty-state" hidden>
    <Alert kind="info" title="No projects yet">
      <p>
        Click <strong>+ New project</strong> above to scaffold one in the browser, or run
        <code>factory init &lt;name&gt;</code> in a terminal. Builds and per-project budget
        defaults will appear here.
      </p>
    </Alert>
  </div>

  <div id="content">
    <p
      id="projects-count"
      style="color: color-mix(in srgb, currentColor 65%, transparent); font-size: 0.9rem; margin-top: 0;"
    >
    </p>
    <Table
      id="projects-table"
      columns={[
        { key: 'name', label: 'Name' },
        { key: 'status', label: 'Status' },
        { key: 'lastTouched', label: 'Last touched' },
        { key: 'workspace', label: 'Workspace' },
        { key: 'lastBuild', label: 'Last build' },
      ]}
      rows={[]}
      loading
    />
  </div>

  <script>
    import {
      apiFetch,
      apiPost,
      captureTokenFromUrl,
      getToken,
      NoTokenError,
      ApiError,
    } from '../../lib/api';

    interface Project {
      id: string;
      name: string;
      workspacePath: string;
      lastTouchedAt: string;
      status: string;
    }
    interface ProjectsList {
      items: Project[];
    }

    interface Directive {
      id: string;
      intent: string;
      status: string;
      projectId?: string;
      createdAt: string;
    }
    interface DirectivesList {
      items: Directive[];
    }
    interface ResumeResponse {
      directive: { id: string };
    }

    const showError = (message: string): void => {
      const err = document.getElementById('error');
      if (err === null) return;
      err.textContent = message;
      err.hidden = false;
    };

    // Tier 10 / 10.5 — build a `projectId -> latest build directive` map
    // from one /api/v1/directives fetch so the projects table can render
    // a per-row "Last build" status + Resume action without N+1 calls.
    const latestBuildByProject = (data: DirectivesList): Map<string, Directive> => {
      const m = new Map<string, Directive>();
      for (const d of data.items) {
        if (d.intent !== 'build') continue;
        if (d.projectId === undefined) continue;
        const existing = m.get(d.projectId);
        if (existing === undefined || d.createdAt > existing.createdAt) {
          m.set(d.projectId, d);
        }
      }
      return m;
    };

    // Per-row resume click handler — mirrors the directive-detail Resume
    // button: POST /api/v1/directives/:id/resume, then nav to the new
    // directive's detail page. Inline error on failure (alert + row UI
    // stays put so the operator can retry).
    const resumeFromProject = async (
      priorId: string,
      btn: HTMLButtonElement,
    ): Promise<void> => {
      const originalText = btn.textContent ?? 'Resume';
      btn.disabled = true;
      btn.textContent = 'Resuming…';
      try {
        const resp = (await apiPost(
          `/api/v1/directives/${encodeURIComponent(priorId)}/resume`,
          {},
        )) as ResumeResponse;
        window.location.href = `/app/directives/detail?id=${encodeURIComponent(resp.directive.id)}`;
      } catch (err: unknown) {
        btn.disabled = false;
        btn.textContent = originalText;
        let message = 'Resume failed';
        if (err instanceof ApiError) {
          message = `Resume failed: ${err.code} (${String(err.status)}) — ${err.message}`;
        } else if (err instanceof NoTokenError) {
          message = err.message;
        } else if (err instanceof Error) {
          message = `Resume failed: ${err.message}`;
        }
        showError(message);
      }
    };

    const renderProjects = (data: ProjectsList, latestById: Map<string, Directive>): void => {
      const content = document.getElementById('content');
      const empty = document.getElementById('empty-state');
      if (data.items.length === 0) {
        if (content !== null) content.hidden = true;
        if (empty !== null) empty.hidden = false;
        return;
      }

      const countEl = document.getElementById('projects-count');
      if (countEl !== null) {
        const plural = data.items.length === 1 ? '' : 's';
        countEl.textContent = `${String(data.items.length)} project${plural}, most-recently touched first.`;
      }

      const tbody = document.querySelector('#projects-table tbody');
      if (tbody === null) return;
      tbody.innerHTML = '';
      for (const p of data.items) {
        const tr = document.createElement('tr');

        const nameTd = document.createElement('td');
        const nameA = document.createElement('a');
        nameA.href = `/app/projects/detail?id=${encodeURIComponent(p.id)}`;
        nameA.className = 'link';
        nameA.textContent = p.name;
        nameTd.appendChild(nameA);
        tr.appendChild(nameTd);

        const statusTd = document.createElement('td');
        statusTd.textContent = p.status;
        tr.appendChild(statusTd);

        const lastTd = document.createElement('td');
        lastTd.textContent = p.lastTouchedAt.replace('T', ' ').slice(0, 19);
        tr.appendChild(lastTd);

        const wsTd = document.createElement('td');
        wsTd.style.cssText =
          'font-family: ui-monospace, SFMono-Regular, Consolas, Menlo, monospace; font-size: 0.85rem; color: color-mix(in srgb, currentColor 75%, transparent);';
        wsTd.textContent = p.workspacePath;
        tr.appendChild(wsTd);

        const lastBuildTd = document.createElement('td');
        const latest = latestById.get(p.id);
        if (latest === undefined) {
          lastBuildTd.style.cssText =
            'color: color-mix(in srgb, currentColor 50%, transparent); font-size: 0.85rem;';
          lastBuildTd.textContent = '—';
        } else {
          const link = document.createElement('a');
          link.href = `/app/directives/detail?id=${encodeURIComponent(latest.id)}`;
          link.className = 'link';
          link.textContent = latest.status;
          link.style.cssText = 'font-family: var(--f-mono, monospace); font-size: 0.85rem;';
          lastBuildTd.appendChild(link);

          // Resume button — only on terminal-non-running directives.
          // Hidden on `running` / `pending` (those need Cancel first;
          // matches the daemon's 409 DIRECTIVE_NOT_TERMINAL refusal).
          if (
            latest.status === 'failed' ||
            latest.status === 'blocked' ||
            latest.status === 'complete'
          ) {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'row-resume-btn';
            btn.textContent = 'Resume';
            btn.addEventListener('click', () => {
              void resumeFromProject(latest.id, btn);
            });
            lastBuildTd.appendChild(btn);
          }
        }
        tr.appendChild(lastBuildTd);

        tbody.appendChild(tr);
      }
    };

    captureTokenFromUrl();

    if (getToken() === null) {
      showError('No UI token present. Reopen the URL logged by factoryd.');
    } else {
      // Two parallel fetches: projects + latest-200 directives. The page
      // could survive with only projects (degraded Last-build column) so
      // failing the directives fetch is non-fatal — show what we have.
      Promise.all([
        apiFetch<ProjectsList>('/api/v1/projects'),
        apiFetch<DirectivesList>('/api/v1/directives?limit=100').catch(() => ({
          items: [] as Directive[],
        })),
      ])
        .then(([projects, directives]) => {
          renderProjects(projects, latestBuildByProject(directives));
        })
        .catch((err: unknown) => {
          if (err instanceof NoTokenError) {
            showError(err.message);
          } else if (err instanceof ApiError) {
            showError(`API error ${String(err.status)} (${err.code}): ${err.message}`);
          } else if (err instanceof Error) {
            showError(`Fetch failed: ${err.message}`);
          } else {
            showError('Unknown error');
          }
        });
    }
  </script>
</Dashboard>
