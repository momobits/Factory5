---
import Dashboard from '../../layouts/Dashboard.astro';
import Table from '../../components/Table.astro';
import Alert from '../../components/Alert.astro';
---

<Dashboard title="Projects">
  <p style="margin: 0 0 1rem 0;">
    <a
      href="/app/projects/new"
      style="color: inherit; font-weight: 600; text-decoration: none; border: 1px solid color-mix(in srgb, currentColor 25%, transparent); padding: 0.35rem 0.85rem; border-radius: 4px; font-size: 0.9rem; display: inline-block;"
    >
      + New project
    </a>
  </p>

  <p id="error" class="err" hidden></p>

  <div id="empty-state" hidden>
    <Alert kind="info" title="No projects yet">
      <p>
        Click <strong>+ New project</strong> above to scaffold one in the browser, or run
        <code>factory init &lt;name&gt;</code> in a terminal. Builds and per-project budget
        defaults will appear here.
      </p>
    </Alert>
  </div>

  <div id="content">
    <p
      id="projects-count"
      style="color: color-mix(in srgb, currentColor 65%, transparent); font-size: 0.9rem; margin-top: 0;"
    >
    </p>
    <Table
      id="projects-table"
      columns={[
        { key: 'name', label: 'Name' },
        { key: 'status', label: 'Status' },
        { key: 'lastTouched', label: 'Last touched' },
        { key: 'workspace', label: 'Workspace' },
      ]}
      rows={[]}
      loading
    />
  </div>

  <script>
    import {
      apiFetch,
      captureTokenFromUrl,
      getToken,
      NoTokenError,
      ApiError,
    } from '../../lib/api';

    interface Project {
      id: string;
      name: string;
      workspacePath: string;
      lastTouchedAt: string;
      status: string;
    }
    interface ProjectsList {
      items: Project[];
    }

    const showError = (message: string): void => {
      const err = document.getElementById('error');
      if (err === null) return;
      err.textContent = message;
      err.hidden = false;
    };

    const renderProjects = (data: ProjectsList): void => {
      const content = document.getElementById('content');
      const empty = document.getElementById('empty-state');
      if (data.items.length === 0) {
        if (content !== null) content.hidden = true;
        if (empty !== null) empty.hidden = false;
        return;
      }

      const countEl = document.getElementById('projects-count');
      if (countEl !== null) {
        const plural = data.items.length === 1 ? '' : 's';
        countEl.textContent = `${String(data.items.length)} project${plural}, most-recently touched first.`;
      }

      const tbody = document.querySelector('#projects-table tbody');
      if (tbody === null) return;
      tbody.innerHTML = '';
      for (const p of data.items) {
        const tr = document.createElement('tr');

        const nameTd = document.createElement('td');
        const nameA = document.createElement('a');
        nameA.href = `/app/projects/detail?id=${encodeURIComponent(p.id)}`;
        nameA.className = 'link';
        nameA.textContent = p.name;
        nameTd.appendChild(nameA);
        tr.appendChild(nameTd);

        const statusTd = document.createElement('td');
        statusTd.textContent = p.status;
        tr.appendChild(statusTd);

        const lastTd = document.createElement('td');
        lastTd.textContent = p.lastTouchedAt.replace('T', ' ').slice(0, 19);
        tr.appendChild(lastTd);

        const wsTd = document.createElement('td');
        wsTd.style.cssText =
          'font-family: ui-monospace, SFMono-Regular, Consolas, Menlo, monospace; font-size: 0.85rem; color: color-mix(in srgb, currentColor 75%, transparent);';
        wsTd.textContent = p.workspacePath;
        tr.appendChild(wsTd);

        tbody.appendChild(tr);
      }
    };

    captureTokenFromUrl();

    if (getToken() === null) {
      showError('No UI token present. Reopen the URL logged by factoryd.');
    } else {
      apiFetch<ProjectsList>('/api/v1/projects')
        .then(renderProjects)
        .catch((err: unknown) => {
          if (err instanceof NoTokenError) {
            showError(err.message);
          } else if (err instanceof ApiError) {
            showError(`API error ${String(err.status)} (${err.code}): ${err.message}`);
          } else if (err instanceof Error) {
            showError(`Fetch failed: ${err.message}`);
          } else {
            showError('Unknown error');
          }
        });
    }
  </script>
</Dashboard>
