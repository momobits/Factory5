---
import Dashboard from '../../layouts/Dashboard.astro';
import Form from '../../components/Form.astro';
import Field from '../../components/Field.astro';
import Submit from '../../components/Submit.astro';
import Alert from '../../components/Alert.astro';
---

<Dashboard title="Project detail">
  <div id="topErrorSlot" hidden>
    <Alert kind="conflict" title="" body="" />
  </div>

  <p id="loading" style="color: color-mix(in srgb, currentColor 65%, transparent);">Loading…</p>

  <div id="content" hidden>
    <h3 id="project-name" style="margin: 0 0 0.25rem 0;"></h3>
    <p
      id="meta-line"
      style="color: color-mix(in srgb, currentColor 65%, transparent); font-size: 0.85rem; margin: 0 0 0.25rem 0;"
    >
    </p>
    <p
      id="workspace-path"
      style="font-family: ui-monospace, SFMono-Regular, Consolas, Menlo, monospace; font-size: 0.85rem; color: color-mix(in srgb, currentColor 75%, transparent); margin: 0 0 1.5rem 0;"
    >
    </p>
    <p id="language-line" style="font-size: 0.9rem; margin: 0 0 1.5rem 0;" hidden>
      <strong>Language: </strong><span id="language-value"></span><span
        style="color: color-mix(in srgb, currentColor 60%, transparent);"
      >
        (from project.json metadata.language)</span
      >
    </p>

    <h3 style="margin: 0 0 0.25rem 0;">Budget defaults</h3>
    <p
      style="color: color-mix(in srgb, currentColor 65%, transparent); font-size: 0.9rem; margin: 0 0 1rem 0; max-width: 36rem;"
    >
      Resolution order per ADR 0027 §4: <code>--max-*</code> flag → project (here) → <code
        >~/.factory5/config.toml</code
      > → unlimited.
    </p>

    <div id="form-success-slot" style="margin-bottom: 1rem;" hidden>
      <Alert kind="success" title="Saved" body="" />
    </div>
    <div id="form-error-slot" style="margin-bottom: 1rem;" hidden>
      <Alert kind="conflict" title="" body="" />
    </div>

    <Form id="budget-form">
      <div class="form-row">
        <Field name="maxUsd" label="Max USD" type="number" step="0.01" min="0" />
        <Field name="maxSteps" label="Max steps" type="number" step="1" min="1" />
      </div>
      <p
        style="font-size: 0.8rem; color: color-mix(in srgb, currentColor 60%, transparent); margin: 0;"
      >
        Empty fields are removed. PUT semantics: the body replaces the entire defaults document.
      </p>
      <div class="form-actions">
        <Submit label="Save defaults" id="save-btn" />
        <button type="button" class="btn btn-danger" id="clear-btn">Clear all defaults</button>
      </div>
    </Form>
  </div>

  <script>
    import {
      ApiError,
      NoTokenError,
      apiFetch,
      apiPut,
      captureTokenFromUrl,
      getToken,
    } from '../../lib/api';

    interface Project {
      id: string;
      name: string;
      workspacePath: string;
      status: string;
      createdAt: string;
      lastTouchedAt: string;
    }
    interface BudgetDefaults {
      maxUsd?: number;
      maxSteps?: number;
    }
    interface DetailResp {
      project: Project;
      budgetDefaults?: BudgetDefaults;
      language?: string;
    }
    interface BudgetResp {
      projectId: string;
      budgetDefaults: BudgetDefaults;
    }

    const setAlertText = (slotId: string, title: string, body: string): void => {
      const slot = document.getElementById(slotId);
      if (slot === null) return;
      const titleEl = slot.querySelector('h4');
      const bodyEl = slot.querySelector('p');
      if (titleEl !== null) titleEl.textContent = title;
      if (bodyEl !== null) bodyEl.textContent = body;
      slot.hidden = false;
    };

    const hideAlert = (slotId: string): void => {
      const slot = document.getElementById(slotId);
      if (slot !== null) slot.hidden = true;
    };

    const codeHeading = (code: string, status: number): string => {
      switch (code) {
        case 'PROJECT_NOT_FOUND':
          return 'Project not found in the registry.';
        case 'PROJECT_PATH_UNREADABLE':
          return 'Workspace path is no longer readable — was the directory moved?';
        case 'PROJECT_METADATA_CORRUPT':
          return 'project.json is unparseable — fix it on disk before saving here.';
        case 'SCHEMA_VALIDATION_FAILED':
          return 'Validation failed — values must be positive numbers.';
        case 'UI_AUTH_REQUIRED':
          return 'Auth token missing or invalid.';
        case 'UI_DISABLED':
          return 'Web UI is disabled on this daemon.';
        case 'NON_LOCALHOST':
          return 'Request rejected as non-localhost.';
        case 'BAD_REQUEST':
          return 'Bad request.';
        case 'INTERNAL':
          return 'Internal server error.';
        default:
          return `Error ${String(status)} (${code})`;
      }
    };

    const renderError = (err: unknown, slotId: string, fallbackTitle: string): void => {
      if (err instanceof ApiError) {
        setAlertText(slotId, codeHeading(err.code, err.status), err.message);
      } else if (err instanceof Error) {
        setAlertText(slotId, fallbackTitle, err.message);
      } else {
        setAlertText(slotId, fallbackTitle, 'Unknown error.');
      }
    };

    const populate = (d: DetailResp): void => {
      const loading = document.getElementById('loading');
      if (loading !== null) loading.hidden = true;
      const content = document.getElementById('content');
      if (content !== null) content.hidden = false;

      const p = d.project;

      const nameEl = document.getElementById('project-name');
      if (nameEl !== null) nameEl.textContent = p.name;

      const meta = document.getElementById('meta-line');
      if (meta !== null) {
        meta.innerHTML = '';
        const code = document.createElement('code');
        code.style.fontSize = '0.95em';
        code.textContent = p.id;
        meta.appendChild(code);
        meta.appendChild(
          document.createTextNode(
            ` · ${p.status} · last touched ${p.lastTouchedAt.replace('T', ' ').slice(0, 19)}`,
          ),
        );
      }

      const ws = document.getElementById('workspace-path');
      if (ws !== null) ws.textContent = p.workspacePath;

      if (d.language !== undefined) {
        const langLine = document.getElementById('language-line');
        const langVal = document.getElementById('language-value');
        if (langVal !== null) langVal.textContent = d.language;
        if (langLine !== null) langLine.hidden = false;
      }

      const usd = document.getElementById('maxUsd') as HTMLInputElement | null;
      const steps = document.getElementById('maxSteps') as HTMLInputElement | null;
      if (usd !== null && d.budgetDefaults?.maxUsd !== undefined) {
        usd.value = String(d.budgetDefaults.maxUsd);
      }
      if (steps !== null && d.budgetDefaults?.maxSteps !== undefined) {
        steps.value = String(d.budgetDefaults.maxSteps);
      }
    };

    const describeBudget = (b: BudgetDefaults): string => {
      const parts: string[] = [];
      if (b.maxUsd !== undefined) parts.push(`maxUsd=${String(b.maxUsd)}`);
      if (b.maxSteps !== undefined) parts.push(`maxSteps=${String(b.maxSteps)}`);
      return parts.length === 0 ? 'All defaults cleared.' : `Saved: ${parts.join(', ')}.`;
    };

    const submitBudget = (
      projectId: string,
      body: Record<string, number>,
      btn: HTMLButtonElement,
      restoreLabel: string,
    ): void => {
      btn.disabled = true;
      btn.textContent = 'Saving…';
      hideAlert('form-success-slot');
      hideAlert('form-error-slot');

      apiPut<typeof body, BudgetResp>(
        `/api/v1/projects/${encodeURIComponent(projectId)}/budget`,
        body,
      )
        .then((resp) => {
          btn.disabled = false;
          btn.textContent = restoreLabel;

          const usd = document.getElementById('maxUsd') as HTMLInputElement | null;
          const steps = document.getElementById('maxSteps') as HTMLInputElement | null;
          if (usd !== null) {
            usd.value =
              resp.budgetDefaults.maxUsd !== undefined ? String(resp.budgetDefaults.maxUsd) : '';
          }
          if (steps !== null) {
            steps.value =
              resp.budgetDefaults.maxSteps !== undefined
                ? String(resp.budgetDefaults.maxSteps)
                : '';
          }
          setAlertText('form-success-slot', 'Saved', describeBudget(resp.budgetDefaults));
        })
        .catch((err: unknown) => {
          btn.disabled = false;
          btn.textContent = restoreLabel;
          renderError(err, 'form-error-slot', 'Save failed');
        });
    };

    const wireForm = (projectId: string): void => {
      const form = document.getElementById('budget-form') as HTMLFormElement | null;
      const saveBtn = document.getElementById('save-btn') as HTMLButtonElement | null;
      const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement | null;
      if (form === null || saveBtn === null || clearBtn === null) return;

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const usd = document.getElementById('maxUsd') as HTMLInputElement;
        const steps = document.getElementById('maxSteps') as HTMLInputElement;
        const body: Record<string, number> = {};
        if (usd.value.trim() !== '') {
          const v = Number.parseFloat(usd.value);
          if (Number.isFinite(v)) body.maxUsd = v;
        }
        if (steps.value.trim() !== '') {
          const v = Number.parseInt(steps.value, 10);
          if (Number.isFinite(v)) body.maxSteps = v;
        }
        submitBudget(projectId, body, saveBtn, 'Save defaults');
      });

      clearBtn.addEventListener('click', () => {
        const ok = window.confirm(
          'Clear all per-project budget defaults? Future builds fall back to instance config or unlimited.',
        );
        if (!ok) return;
        submitBudget(projectId, {}, clearBtn, 'Clear all defaults');
      });
    };

    captureTokenFromUrl();

    const projectId = new URLSearchParams(window.location.search).get('id');

    if (projectId === null || projectId.length === 0) {
      const loading = document.getElementById('loading');
      if (loading !== null) loading.textContent = 'Missing ?id=<projectId> in URL.';
    } else if (getToken() === null) {
      const loading = document.getElementById('loading');
      if (loading !== null) {
        loading.textContent = 'No UI token present. Reopen the URL logged by factoryd.';
      }
    } else {
      const id = projectId;
      apiFetch<DetailResp>(`/api/v1/projects/${encodeURIComponent(id)}`)
        .then((resp) => {
          populate(resp);
          wireForm(id);
        })
        .catch((err: unknown) => {
          const loading = document.getElementById('loading');
          if (err instanceof NoTokenError) {
            if (loading !== null) loading.textContent = err.message;
            return;
          }
          if (loading !== null) loading.hidden = true;
          renderError(err, 'topErrorSlot', 'Failed to load project');
        });
    }
  </script>
</Dashboard>
