---
import Dashboard from '../layouts/Dashboard.astro';
import Card from '../components/Card.astro';
---

<Dashboard title="Overview">
  <p id="error" class="err" hidden></p>
  <div class="cards">
    <Card title="Directives (total)" value="—" id="card-directives-total" />
    <Card title="Open questions" value="—" id="card-questions-open" />
    <Card title="Today spend" value="—" id="card-spend-today" />
    <Card title="All-time spend" value="—" id="card-spend-alltime" />
    <Card title="Open findings" value="—" id="card-findings-open" />
  </div>
  <p style="margin-top: 1.5rem;">
    Use the nav to drill into each section. Pending questions are the most
    time-sensitive — answer via Telegram / Discord / CLI.
  </p>

  <script>
    import { apiFetch, captureTokenFromUrl, getToken, NoTokenError, ApiError } from '../lib/api';

    interface Directive {
      id: string;
      status: string;
    }
    interface DirectivesList {
      items: Directive[];
      total: number;
    }
    interface PendingQuestion {
      id: string;
    }
    interface QuestionsList {
      total: number;
      items: PendingQuestion[];
    }
    interface SpendResp {
      perDirective: Array<{ totalUsd: number }>;
      perDay: Array<{ date: string; totalUsd: number }>;
    }
    interface Finding {
      finding: { severity: string; status: string };
    }
    interface FindingsList {
      items: Finding[];
    }

    const setCard = (cardId: string, value: string): void => {
      const cell = document.querySelector(`#${cardId} .value`);
      if (cell !== null) cell.textContent = value;
    };

    const showError = (message: string): void => {
      const err = document.getElementById('error');
      if (err === null) return;
      err.textContent = message;
      err.hidden = false;
    };

    captureTokenFromUrl();

    if (getToken() === null) {
      showError('No UI token present. Reopen the URL logged by factoryd.');
    } else {
      Promise.all([
        apiFetch<DirectivesList>('/api/v1/directives?limit=1'),
        apiFetch<QuestionsList>('/api/v1/pending-questions?limit=1'),
        apiFetch<SpendResp>('/api/v1/spend'),
        apiFetch<FindingsList>('/api/v1/findings?limit=500'),
      ])
        .then(([directives, questions, spendResp, findings]) => {
          const todayIso = new Date().toISOString().slice(0, 10);
          const todaySpend = spendResp.perDay.find((d) => d.date === todayIso)?.totalUsd ?? 0;
          const allTimeSpend = spendResp.perDirective.reduce(
            (a: number, d) => a + d.totalUsd,
            0,
          );
          const openFindings = findings.items.filter((e) => e.finding.status === 'OPEN').length;

          setCard('card-directives-total', String(directives.total));
          setCard('card-questions-open', String(questions.total));
          setCard('card-spend-today', `$${todaySpend.toFixed(2)}`);
          setCard('card-spend-alltime', `$${allTimeSpend.toFixed(2)}`);
          setCard('card-findings-open', String(openFindings));
        })
        .catch((err: unknown) => {
          if (err instanceof NoTokenError) {
            showError(err.message);
          } else if (err instanceof ApiError) {
            showError(`API error ${String(err.status)} (${err.code}): ${err.message}`);
          } else if (err instanceof Error) {
            showError(`Fetch failed: ${err.message}`);
          } else {
            showError('Unknown error');
          }
        });
    }
  </script>
</Dashboard>
