---
import Dashboard from '../../layouts/Dashboard.astro';
import Table from '../../components/Table.astro';
---

<Dashboard title="Findings">
  <form class="filter-form" id="filter">
    <label>
      Severity:
      <select name="severity">
        <option value="">all</option>
        <option value="LOW">LOW</option>
        <option value="MEDIUM">MEDIUM</option>
        <option value="HIGH">HIGH</option>
        <option value="CRITICAL">CRITICAL</option>
      </select>
    </label>
    <label>
      Status:
      <select name="status">
        <option value="">all</option>
        <option value="OPEN">OPEN</option>
        <option value="FIXED">FIXED</option>
        <option value="VERIFIED">VERIFIED</option>
        <option value="WONTFIX">WONTFIX</option>
      </select>
    </label>
    <label>
      Project (id or glob):
      <input name="project" type="text" placeholder="ULID or *acme*" style="width: 14rem;" />
    </label>
    <label>
      Advisory:
      <select name="advisory">
        <option value="">both</option>
        <option value="true">advisory only</option>
        <option value="false">blocking only</option>
      </select>
    </label>
    <button type="submit">Apply</button>
  </form>

  <p id="error" class="err" hidden></p>
  <p id="findings-count"></p>
  <Table
    id="findings-table"
    columns={[
      { key: 'updated', label: 'Updated' },
      { key: 'id', label: 'Id' },
      { key: 'severity', label: 'Severity' },
      { key: 'status', label: 'Status' },
      { key: 'source', label: 'Source' },
      { key: 'target', label: 'Target' },
      { key: 'description', label: 'Description' },
      { key: 'advisory', label: 'Advisory' },
    ]}
    rows={[]}
    loading
  />

  <script>
    import {
      apiFetch,
      captureTokenFromUrl,
      getToken,
      NoTokenError,
      ApiError,
    } from '../../lib/api';

    interface FindingLocation {
      file: string;
      line?: number;
      anchor?: string;
      frontmatter_field?: string;
    }

    interface Finding {
      id: string;
      source: string;
      target: string;
      severity: string;
      status: string;
      description: string;
      createdAt: string;
      advisory?: boolean;
      // Tier 15.13 — structured fields (optional for backward compat).
      category?: string;
      location?: FindingLocation;
      title?: string;
      why?: string;
      suggested_fix?: string;
      auto_fixable?: boolean;
    }
    interface Entry {
      projectId: string;
      projectPath: string;
      finding: Finding;
      originDirectiveId?: string;
      updatedAt: string;
    }
    interface ListResp {
      items: Entry[];
    }

    const showError = (message: string): void => {
      const err = document.getElementById('error');
      if (err === null) return;
      err.textContent = message;
      err.hidden = false;
    };

    function formatLocation(
      loc:
        | { file: string; line?: number; anchor?: string; frontmatter_field?: string }
        | undefined,
    ): string {
      if (loc === undefined) return '';
      let s = loc.file;
      if (loc.line !== undefined) s += `:${String(loc.line)}`;
      if (loc.anchor !== undefined && loc.anchor.length > 0) s += ` (${loc.anchor})`;
      if (loc.frontmatter_field !== undefined && loc.frontmatter_field.length > 0)
        s += ` [front-matter: ${loc.frontmatter_field}]`;
      return s;
    }

    function buildDescriptionCell(f: Finding): HTMLElement {
      const cell = document.createElement('div');
      const isStructured = typeof f.title === 'string' && f.title.length > 0;
      if (isStructured) {
        cell.className = 'finding-structured';
        const titleEl = document.createElement('div');
        titleEl.className = 'finding-title';
        titleEl.textContent = f.title ?? '';
        cell.appendChild(titleEl);

        const metaEl = document.createElement('div');
        metaEl.className = 'finding-meta';
        if (f.category !== undefined && f.category.length > 0) {
          const cat = document.createElement('span');
          cat.className = 'finding-category';
          cat.textContent = f.category;
          metaEl.appendChild(cat);
        }
        if (f.auto_fixable === true) {
          const autofix = document.createElement('span');
          autofix.className = 'finding-autofix';
          autofix.textContent = 'auto-fixable';
          metaEl.appendChild(autofix);
        }
        const loc = formatLocation(f.location);
        if (loc.length > 0) {
          const locEl = document.createElement('span');
          locEl.className = 'finding-location';
          locEl.textContent = loc;
          metaEl.appendChild(locEl);
        }
        if (metaEl.childNodes.length > 0) cell.appendChild(metaEl);

        if (typeof f.why === 'string' && f.why.length > 0) {
          const why = document.createElement('div');
          why.className = 'finding-why';
          const label = document.createElement('strong');
          label.textContent = 'Why: ';
          why.appendChild(label);
          why.appendChild(document.createTextNode(f.why));
          cell.appendChild(why);
        }
        if (typeof f.suggested_fix === 'string' && f.suggested_fix.length > 0) {
          const fix = document.createElement('div');
          fix.className = 'finding-fix';
          const label = document.createElement('strong');
          label.textContent = 'Fix: ';
          fix.appendChild(label);
          fix.appendChild(document.createTextNode(f.suggested_fix));
          cell.appendChild(fix);
        }
      } else {
        // Legacy fallback: render the description as plain text.
        cell.textContent = f.description;
      }
      return cell;
    }

    const renderRows = (resp: ListResp): void => {
      const tbody = document.querySelector('#findings-table tbody');
      const countEl = document.getElementById('findings-count');
      if (tbody === null) return;
      tbody.innerHTML = '';
      if (countEl !== null) countEl.textContent = `${String(resp.items.length)} findings`;
      if (resp.items.length === 0) {
        const colCount = document.querySelectorAll('#findings-table thead th').length;
        const tr = document.createElement('tr');
        const td = document.createElement('td');
        td.colSpan = colCount;
        td.className = 'empty';
        td.textContent = 'No findings match.';
        tr.appendChild(td);
        tbody.appendChild(tr);
        return;
      }
      for (const e of resp.items) {
        const tr = document.createElement('tr');
        // First 6 cells are plain text.
        const stringCells: Array<string> = [
          e.updatedAt.slice(0, 19).replace('T', ' '),
          e.finding.id,
          e.finding.severity,
          e.finding.status,
          e.finding.source,
          e.finding.target,
        ];
        for (const cell of stringCells) {
          const td = document.createElement('td');
          td.textContent = cell;
          tr.appendChild(td);
        }
        // Description cell — structured-aware.
        const descTd = document.createElement('td');
        descTd.appendChild(buildDescriptionCell(e.finding));
        tr.appendChild(descTd);
        // Advisory cell.
        const advTd = document.createElement('td');
        advTd.textContent = e.finding.advisory === true ? 'advisory' : '';
        tr.appendChild(advTd);

        tbody.appendChild(tr);
      }
    };

    const mountPath = (): string => {
      const params = new URLSearchParams(window.location.search);
      const qs: string[] = [];
      for (const key of ['severity', 'status', 'project', 'advisory']) {
        const v = params.get(key);
        if (v !== null && v.length > 0) qs.push(`${key}=${encodeURIComponent(v)}`);
      }
      qs.push('limit=500');
      return `/api/v1/findings?${qs.join('&')}`;
    };

    captureTokenFromUrl();

    if (getToken() === null) {
      showError('No UI token present. Reopen the URL logged by factoryd.');
    } else {
      apiFetch<ListResp>(mountPath())
        .then(renderRows)
        .catch((err: unknown) => {
          if (err instanceof NoTokenError) {
            showError(err.message);
          } else if (err instanceof ApiError) {
            showError(`API error ${String(err.status)} (${err.code}): ${err.message}`);
          } else if (err instanceof Error) {
            showError(`Fetch failed: ${err.message}`);
          } else {
            showError('Unknown error');
          }
        });
    }

    const form = document.getElementById('filter') as HTMLFormElement | null;
    if (form !== null) {
      const params = new URLSearchParams(window.location.search);
      for (const key of ['severity', 'status', 'project', 'advisory']) {
        const input = form.elements.namedItem(key) as
          | HTMLInputElement
          | HTMLSelectElement
          | null;
        if (input !== null) input.value = params.get(key) ?? '';
      }
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const sd = new FormData(form);
        const nextParams = new URLSearchParams();
        for (const key of ['severity', 'status', 'project', 'advisory']) {
          const v = String(sd.get(key) ?? '');
          if (v.length > 0) nextParams.set(key, v);
        }
        window.location.search =
          nextParams.toString().length > 0 ? `?${nextParams.toString()}` : '';
      });
    }
  </script>
</Dashboard>
