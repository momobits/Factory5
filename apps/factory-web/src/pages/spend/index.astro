---
import Dashboard from '../../layouts/Dashboard.astro';
import Table from '../../components/Table.astro';
---

<Dashboard title="Spend">
  <form class="filter-form" id="filter">
    <label>
      Since (ISO):
      <input name="since" type="text" placeholder="2026-04-01T00:00:00Z" style="width: 14rem;" />
    </label>
    <label>
      Until (ISO):
      <input name="until" type="text" placeholder="2026-05-01T00:00:00Z" style="width: 14rem;" />
    </label>
    <label>
      Project:
      <input name="projectId" type="text" placeholder="ULID" style="width: 14rem;" />
    </label>
    <button type="submit">Apply</button>
  </form>

  <p id="error" class="err" hidden></p>

  <h3 style="margin-top: 1.5rem;">
    Per project (<span id="spend-perproject-count">…</span>)
  </h3>
  <Table
    id="spend-perproject"
    columns={[
      { key: 'project', label: 'Project' },
      { key: 'directives', label: 'Directives', numeric: true },
      { key: 'calls', label: 'Calls', numeric: true },
      { key: 'total', label: 'Total', numeric: true },
    ]}
    rows={[]}
    loading
  />

  <h3 style="margin-top: 1.5rem;">
    Per day (<span id="spend-perday-count">…</span>)
  </h3>
  <Table
    id="spend-perday"
    columns={[
      { key: 'date', label: 'Date' },
      { key: 'calls', label: 'Calls', numeric: true },
      { key: 'total', label: 'Total', numeric: true },
    ]}
    rows={[]}
    loading
  />

  <h3 style="margin-top: 1.5rem;">
    Per model (<span id="spend-permodel-count">…</span>)
  </h3>
  <Table
    id="spend-permodel"
    columns={[
      { key: 'provider', label: 'Provider' },
      { key: 'model', label: 'Model' },
      { key: 'calls', label: 'Calls', numeric: true },
      { key: 'total', label: 'Total', numeric: true },
    ]}
    rows={[]}
    loading
  />

  <h3 style="margin-top: 1.5rem;">
    Per directive (<span id="spend-perdirective-count">…</span>)
  </h3>
  <Table
    id="spend-perdirective"
    columns={[
      { key: 'directive', label: 'Directive' },
      { key: 'project', label: 'Project' },
      { key: 'first', label: 'First' },
      { key: 'last', label: 'Last' },
      { key: 'calls', label: 'Calls', numeric: true },
      { key: 'total', label: 'Total', numeric: true },
    ]}
    rows={[]}
    loading
  />

  <script>
    import {
      apiFetch,
      captureTokenFromUrl,
      getToken,
      NoTokenError,
      ApiError,
      fmtUsd,
    } from '../../lib/api';

    interface PerProject {
      projectId: string | null;
      display: string;
      totalUsd: number;
      callCount: number;
      directiveCount: number;
    }
    interface PerDirective {
      directiveId: string;
      projectName: string | null;
      totalUsd: number;
      callCount: number;
      firstCalledAt: string;
      lastCalledAt: string;
    }
    interface PerDay {
      date: string;
      totalUsd: number;
      callCount: number;
    }
    interface PerModel {
      provider: string;
      model: string;
      totalUsd: number;
      callCount: number;
    }
    interface SpendResp {
      perProject: PerProject[];
      perDirective: PerDirective[];
      perDay: PerDay[];
      perModel: PerModel[];
    }

    const showError = (message: string): void => {
      const err = document.getElementById('error');
      if (err === null) return;
      err.textContent = message;
      err.hidden = false;
    };

    const fillTable = <T,>(
      tableId: string,
      countId: string,
      rows: T[],
      buildRow: (item: T) => HTMLTableRowElement,
    ): void => {
      const countEl = document.getElementById(countId);
      if (countEl !== null) countEl.textContent = String(rows.length);
      const tbody = document.querySelector(`#${tableId} tbody`);
      if (tbody === null) return;
      tbody.innerHTML = '';
      if (rows.length === 0) {
        const colCount = document.querySelectorAll(`#${tableId} thead th`).length;
        const tr = document.createElement('tr');
        const td = document.createElement('td');
        td.colSpan = colCount;
        td.className = 'empty';
        td.textContent = tableId === 'spend-perproject' ? 'No spend recorded.' : 'None.';
        tr.appendChild(td);
        tbody.appendChild(tr);
        return;
      }
      for (const r of rows) tbody.appendChild(buildRow(r));
    };

    const td = (text: string, numeric = false): HTMLTableCellElement => {
      const e = document.createElement('td');
      e.textContent = text;
      if (numeric) e.className = 'num';
      return e;
    };

    const renderSpend = (resp: SpendResp): void => {
      fillTable<PerProject>('spend-perproject', 'spend-perproject-count', resp.perProject, (p) => {
        const tr = document.createElement('tr');
        tr.appendChild(td(p.display));
        tr.appendChild(td(String(p.directiveCount), true));
        tr.appendChild(td(String(p.callCount), true));
        tr.appendChild(td(fmtUsd(p.totalUsd), true));
        return tr;
      });

      fillTable<PerDay>('spend-perday', 'spend-perday-count', resp.perDay, (d) => {
        const tr = document.createElement('tr');
        tr.appendChild(td(d.date));
        tr.appendChild(td(String(d.callCount), true));
        tr.appendChild(td(fmtUsd(d.totalUsd), true));
        return tr;
      });

      fillTable<PerModel>('spend-permodel', 'spend-permodel-count', resp.perModel, (m) => {
        const tr = document.createElement('tr');
        tr.appendChild(td(m.provider));
        tr.appendChild(td(m.model));
        tr.appendChild(td(String(m.callCount), true));
        tr.appendChild(td(fmtUsd(m.totalUsd), true));
        return tr;
      });

      fillTable<PerDirective>(
        'spend-perdirective',
        'spend-perdirective-count',
        resp.perDirective,
        (d) => {
          const tr = document.createElement('tr');
          const dirTd = document.createElement('td');
          const a = document.createElement('a');
          a.href = `/app/directives/detail?id=${encodeURIComponent(d.directiveId)}`;
          a.className = 'link';
          a.textContent = d.directiveId.slice(-8);
          dirTd.appendChild(a);
          tr.appendChild(dirTd);
          tr.appendChild(td(d.projectName ?? ''));
          tr.appendChild(td(d.firstCalledAt.slice(0, 19).replace('T', ' ')));
          tr.appendChild(td(d.lastCalledAt.slice(0, 19).replace('T', ' ')));
          tr.appendChild(td(String(d.callCount), true));
          tr.appendChild(td(fmtUsd(d.totalUsd), true));
          return tr;
        },
      );
    };

    const mountPath = (): string => {
      const params = new URLSearchParams(window.location.search);
      const qs: string[] = [];
      for (const key of ['since', 'until', 'projectId']) {
        const v = params.get(key);
        if (v !== null && v.length > 0) qs.push(`${key}=${encodeURIComponent(v)}`);
      }
      return `/api/v1/spend${qs.length > 0 ? '?' + qs.join('&') : ''}`;
    };

    captureTokenFromUrl();

    if (getToken() === null) {
      showError('No UI token present. Reopen the URL logged by factoryd.');
    } else {
      apiFetch<SpendResp>(mountPath())
        .then(renderSpend)
        .catch((err: unknown) => {
          if (err instanceof NoTokenError) {
            showError(err.message);
          } else if (err instanceof ApiError) {
            showError(`API error ${String(err.status)} (${err.code}): ${err.message}`);
          } else if (err instanceof Error) {
            showError(`Fetch failed: ${err.message}`);
          } else {
            showError('Unknown error');
          }
        });
    }

    const form = document.getElementById('filter') as HTMLFormElement | null;
    if (form !== null) {
      const params = new URLSearchParams(window.location.search);
      for (const key of ['since', 'until', 'projectId']) {
        const input = form.elements.namedItem(key) as HTMLInputElement | null;
        if (input !== null) input.value = params.get(key) ?? '';
      }
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const sd = new FormData(form);
        const nextParams = new URLSearchParams();
        for (const key of ['since', 'until', 'projectId']) {
          const v = String(sd.get(key) ?? '');
          if (v.length > 0) nextParams.set(key, v);
        }
        window.location.search =
          nextParams.toString().length > 0 ? `?${nextParams.toString()}` : '';
      });
    }
  </script>
</Dashboard>
