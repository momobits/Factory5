---
import Dashboard from '../../layouts/Dashboard.astro';
import Table from '../../components/Table.astro';
---

<Dashboard title="Pending questions">
  <form class="filter-form" id="filter">
    <label>
      Status:
      <select name="status">
        <option value="open" selected>open</option>
        <option value="answered">answered</option>
        <option value="all">all</option>
      </select>
    </label>
    <label>
      Limit:
      <input name="limit" type="number" min="1" max="100" value="50" style="width: 4rem;" />
    </label>
    <button type="submit">Apply</button>
  </form>

  <p id="error" class="err" hidden></p>
  <p id="questions-count"></p>
  <Table
    id="questions-table"
    columns={[
      { key: 'created', label: 'Created' },
      { key: 'question', label: 'Question' },
      { key: 'channel', label: 'Channel' },
      { key: 'directive', label: 'Directive' },
      { key: 'answer', label: 'Answer' },
      { key: 'answered_by', label: 'Answered by' },
    ]}
    rows={[]}
    loading
  />

  <script>
    import {
      apiFetch,
      captureTokenFromUrl,
      getToken,
      NoTokenError,
      ApiError,
    } from '../../lib/api';

    type AnsweredBy = 'user' | 'agent' | 'agent-failed' | 'orphan-sweep';
    interface PendingQuestion {
      id: string;
      directiveId: string;
      question: string;
      channel: string;
      createdAt: string;
      answeredAt?: string;
      answer?: string;
      answeredBy?: AnsweredBy;
    }
    interface ListResp {
      items: PendingQuestion[];
      total: number;
      status: string;
    }

    const showError = (message: string): void => {
      const err = document.getElementById('error');
      if (err === null) return;
      err.textContent = message;
      err.hidden = false;
    };

    const renderQuestions = (resp: ListResp): void => {
      const tbody = document.querySelector('#questions-table tbody');
      const countEl = document.getElementById('questions-count');
      if (tbody === null) return;
      if (countEl !== null) {
        countEl.textContent = `${String(resp.items.length)} of ${String(resp.total)} (status: ${resp.status})`;
      }
      tbody.innerHTML = '';
      if (resp.items.length === 0) {
        const colCount = document.querySelectorAll('#questions-table thead th').length;
        const tr = document.createElement('tr');
        const td = document.createElement('td');
        td.colSpan = colCount;
        td.className = 'empty';
        td.textContent = 'Nothing pending.';
        tr.appendChild(td);
        tbody.appendChild(tr);
        return;
      }
      for (const q of resp.items) {
        const tr = document.createElement('tr');

        const createdTd = document.createElement('td');
        createdTd.textContent = q.createdAt.slice(0, 19).replace('T', ' ');
        tr.appendChild(createdTd);

        const questionTd = document.createElement('td');
        const questionA = document.createElement('a');
        questionA.href = `/app/questions/detail?id=${encodeURIComponent(q.id)}`;
        questionA.className = 'link';
        questionA.textContent = q.question;
        questionTd.appendChild(questionA);
        tr.appendChild(questionTd);

        const channelTd = document.createElement('td');
        channelTd.textContent = q.channel;
        tr.appendChild(channelTd);

        const directiveTd = document.createElement('td');
        const directiveA = document.createElement('a');
        directiveA.href = `/app/directives/detail?id=${encodeURIComponent(q.directiveId)}`;
        directiveA.className = 'link';
        directiveA.textContent = q.directiveId.slice(-8);
        directiveTd.appendChild(directiveA);
        tr.appendChild(directiveTd);

        const answerTd = document.createElement('td');
        answerTd.textContent = q.answer ?? '';
        tr.appendChild(answerTd);

        const answeredByTd = document.createElement('td');
        answeredByTd.textContent = renderAnsweredBy(q.answeredBy);
        tr.appendChild(answeredByTd);

        tbody.appendChild(tr);
      }
    };

    /**
     * Render the answered_by column. Empty when unanswered (so open-status
     * rows render a blank cell instead of "(unknown)"); structured tag
     * otherwise so the operator can spot agent vs human answers at a glance.
     * Tier 8 / ADR 0030.
     */
    const renderAnsweredBy = (by: AnsweredBy | undefined): string => {
      if (by === undefined) return '';
      if (by === 'user') return 'human';
      if (by === 'agent') return 'agent (auto)';
      if (by === 'agent-failed') return 'agent (LLM failed)';
      return 'orphan sweep';
    };

    const mountPath = (): string => {
      const params = new URLSearchParams(window.location.search);
      const status = params.get('status') ?? 'open';
      const limit = params.get('limit') ?? '50';
      return `/api/v1/pending-questions?status=${encodeURIComponent(status)}&limit=${encodeURIComponent(limit)}`;
    };

    captureTokenFromUrl();

    if (getToken() === null) {
      showError('No UI token present. Reopen the URL logged by factoryd.');
    } else {
      apiFetch<ListResp>(mountPath())
        .then(renderQuestions)
        .catch((err: unknown) => {
          if (err instanceof NoTokenError) {
            showError(err.message);
          } else if (err instanceof ApiError) {
            showError(`API error ${String(err.status)} (${err.code}): ${err.message}`);
          } else if (err instanceof Error) {
            showError(`Fetch failed: ${err.message}`);
          } else {
            showError('Unknown error');
          }
        });
    }

    const form = document.getElementById('filter') as HTMLFormElement | null;
    if (form !== null) {
      const params = new URLSearchParams(window.location.search);
      const statusSel = form.elements.namedItem('status') as HTMLSelectElement | null;
      const limitInput = form.elements.namedItem('limit') as HTMLInputElement | null;
      if (statusSel !== null) statusSel.value = params.get('status') ?? 'open';
      if (limitInput !== null) limitInput.value = params.get('limit') ?? '50';
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const sd = new FormData(form);
        const nextParams = new URLSearchParams();
        nextParams.set('status', String(sd.get('status') ?? 'open'));
        nextParams.set('limit', String(sd.get('limit') ?? '50'));
        window.location.search = `?${nextParams.toString()}`;
      });
    }
  </script>
</Dashboard>
