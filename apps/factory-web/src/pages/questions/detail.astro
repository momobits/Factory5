---
import Dashboard from '../../layouts/Dashboard.astro';
import Form from '../../components/Form.astro';
import Field from '../../components/Field.astro';
import Submit from '../../components/Submit.astro';
import Alert from '../../components/Alert.astro';
---

<Dashboard title="Question detail">
  <div id="topErrorSlot" hidden>
    <Alert kind="conflict" title="" body="" />
  </div>

  <p id="loading" style="color: color-mix(in srgb, currentColor 65%, transparent);">Loading…</p>

  <div id="content" hidden>
    <p id="question-text" style="font-size: 1.1rem; margin-top: 0;"></p>

    <div id="form-success-slot" style="margin-bottom: 1rem;" hidden>
      <Alert
        kind="success"
        title="Answered"
        body="The waiting worker (if any) will resume on its next poll."
      />
    </div>
    <div id="form-error-slot" style="margin-bottom: 1rem;" hidden>
      <Alert kind="conflict" title="" body="" />
    </div>

    <table id="question-meta">
      <tbody></tbody>
    </table>

    <div id="answer-form-wrapper" hidden style="margin-top: 2rem;">
      <h3 style="margin: 0 0 0.5rem 0;">Answer</h3>
      <p
        style="font-size: 0.8rem; color: color-mix(in srgb, currentColor 60%, transparent); margin: 0 0 1rem 0; max-width: 36rem;"
      >
        Posts through the same path Discord and Telegram inbound take. The first answer wins;
        conflicting later answers return 409 with the original preserved.
      </p>

      <Form id="answer-form">
        <Field name="answer" label="Answer text" type="textarea" required />
        <p
          id="suggested-answers"
          style="font-size: 0.8rem; color: color-mix(in srgb, currentColor 60%, transparent); margin: 0;"
          hidden
        >
        </p>
        <div class="form-actions">
          <Submit label="Submit answer" id="answer-submit" />
        </div>
      </Form>
    </div>
  </div>

  <script>
    import {
      ApiError,
      NoTokenError,
      apiFetch,
      apiPost,
      captureTokenFromUrl,
      getToken,
    } from '../../lib/api';

    type AnsweredBy = 'user' | 'agent' | 'agent-failed' | 'orphan-sweep';
    interface PendingQuestion {
      id: string;
      directiveId: string;
      taskId?: string;
      question: string;
      options?: string[];
      channel: string;
      channelRef: string;
      createdAt: string;
      deadlineAt?: string;
      answeredAt?: string;
      answer?: string;
      answeredBy?: AnsweredBy;
    }
    interface DetailResp {
      question: PendingQuestion;
    }
    interface AnswerResp {
      question: PendingQuestion;
    }

    const setAlertText = (slotId: string, title: string, body: string): void => {
      const slot = document.getElementById(slotId);
      if (slot === null) return;
      const titleEl = slot.querySelector('h4');
      const bodyEl = slot.querySelector('p');
      if (titleEl !== null) titleEl.textContent = title;
      if (bodyEl !== null) bodyEl.textContent = body;
      slot.hidden = false;
    };

    const hideAlert = (slotId: string): void => {
      const slot = document.getElementById(slotId);
      if (slot !== null) slot.hidden = true;
    };

    const codeHeading = (code: string, status: number): string => {
      switch (code) {
        case 'QUESTION_NOT_FOUND':
          return 'Question not found.';
        case 'QUESTION_ALREADY_ANSWERED_DIFFERENTLY':
          return 'Question was already answered.';
        case 'SCHEMA_VALIDATION_FAILED':
          return 'Validation failed — answer cannot be empty.';
        case 'UI_AUTH_REQUIRED':
          return 'Auth token missing or invalid.';
        case 'UI_DISABLED':
          return 'Web UI is disabled on this daemon.';
        case 'NON_LOCALHOST':
          return 'Request rejected as non-localhost.';
        case 'BAD_REQUEST':
          return 'Bad request.';
        case 'INTERNAL':
          return 'Internal server error.';
        default:
          return `Error ${String(status)} (${code})`;
      }
    };

    const renderError = (err: unknown, slotId: string, fallbackTitle: string): void => {
      if (err instanceof ApiError) {
        setAlertText(slotId, codeHeading(err.code, err.status), err.message);
      } else if (err instanceof Error) {
        setAlertText(slotId, fallbackTitle, err.message);
      } else {
        setAlertText(slotId, fallbackTitle, 'Unknown error.');
      }
    };

    const buildMetaRow = (
      key: string,
      value: string | HTMLElement,
    ): HTMLTableRowElement => {
      const tr = document.createElement('tr');
      const tdKey = document.createElement('td');
      const strong = document.createElement('strong');
      strong.textContent = key;
      tdKey.appendChild(strong);
      const tdVal = document.createElement('td');
      if (typeof value === 'string') tdVal.textContent = value;
      else tdVal.appendChild(value);
      tr.appendChild(tdKey);
      tr.appendChild(tdVal);
      return tr;
    };

    /**
     * Render `answered_by` as operator-readable text. Tier 8 / ADR 0030.
     */
    const renderAnsweredBy = (by: AnsweredBy): string => {
      if (by === 'user') return 'human';
      if (by === 'agent') return 'agent (auto-answered after deadline)';
      if (by === 'agent-failed') return 'agent (LLM failed; synthetic placeholder)';
      return 'orphan sweep (directive ended unanswered)';
    };

    const renderSuggestedAnswers = (q: PendingQuestion): void => {
      const slot = document.getElementById('suggested-answers');
      const ta = document.getElementById('answer') as HTMLTextAreaElement | null;
      if (slot === null || ta === null) return;
      slot.innerHTML = '';
      if (q.options === undefined || q.options.length === 0) {
        slot.hidden = true;
        return;
      }
      slot.hidden = false;
      slot.appendChild(document.createTextNode('Suggested answers: '));
      q.options.forEach((opt, idx) => {
        if (idx > 0) slot.appendChild(document.createTextNode(', '));
        const a = document.createElement('a');
        a.href = '#';
        a.className = 'link';
        a.style.textDecoration = 'underline';
        a.textContent = opt;
        a.addEventListener('click', (e) => {
          e.preventDefault();
          ta.value = opt;
          ta.focus();
        });
        slot.appendChild(a);
      });
    };

    const populate = (resp: DetailResp): void => {
      const q = resp.question;
      const loading = document.getElementById('loading');
      if (loading !== null) loading.hidden = true;
      const content = document.getElementById('content');
      if (content !== null) content.hidden = false;

      const questionText = document.getElementById('question-text');
      if (questionText !== null) questionText.textContent = q.question;

      const tbody = document.querySelector('#question-meta tbody');
      if (tbody !== null) {
        tbody.innerHTML = '';
        tbody.appendChild(buildMetaRow('Id', q.id));

        const directiveLink = document.createElement('a');
        directiveLink.href = `/app/directives/detail?id=${encodeURIComponent(q.directiveId)}`;
        directiveLink.className = 'link';
        directiveLink.textContent = q.directiveId;
        tbody.appendChild(buildMetaRow('Directive', directiveLink));

        if (q.taskId !== undefined) tbody.appendChild(buildMetaRow('Task', q.taskId));
        tbody.appendChild(buildMetaRow('Channel', `${q.channel} (${q.channelRef})`));
        tbody.appendChild(buildMetaRow('Created', q.createdAt.replace('T', ' ').slice(0, 19)));
        if (q.deadlineAt !== undefined) {
          tbody.appendChild(buildMetaRow('Deadline', q.deadlineAt.replace('T', ' ').slice(0, 19)));
        }
        if (q.options !== undefined && q.options.length > 0) {
          tbody.appendChild(buildMetaRow('Options', q.options.join(', ')));
        }
        tbody.appendChild(
          buildMetaRow('Status', q.answeredAt !== undefined ? `Answered at ${q.answeredAt}` : 'Open'),
        );
        if (q.answeredBy !== undefined) {
          tbody.appendChild(buildMetaRow('Answered by', renderAnsweredBy(q.answeredBy)));
        }
        if (q.answer !== undefined) tbody.appendChild(buildMetaRow('Answer', q.answer));
      }

      const formWrap = document.getElementById('answer-form-wrapper');
      if (formWrap !== null) {
        if (q.answeredAt === undefined) {
          formWrap.hidden = false;
          renderSuggestedAnswers(q);
        } else {
          formWrap.hidden = true;
        }
      }
    };

    const load = (qid: string): Promise<DetailResp> => {
      return apiFetch<DetailResp>(`/api/v1/pending-questions/${encodeURIComponent(qid)}`);
    };

    const wireForm = (qid: string): void => {
      const form = document.getElementById('answer-form') as HTMLFormElement | null;
      const submit = document.getElementById('answer-submit') as HTMLButtonElement | null;
      const ta = document.getElementById('answer') as HTMLTextAreaElement | null;
      if (form === null || submit === null || ta === null) return;

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        if (submit.disabled) return;
        const answer = ta.value.trim();
        if (answer.length === 0) {
          setAlertText('form-error-slot', 'Bad request.', 'Answer cannot be empty.');
          return;
        }
        submit.disabled = true;
        submit.textContent = 'Submitting…';
        hideAlert('form-success-slot');
        hideAlert('form-error-slot');

        apiPost<{ answer: string }, AnswerResp>(
          `/api/v1/pending-questions/${encodeURIComponent(qid)}/answer`,
          { answer },
        )
          .then((resp) => {
            populate({ question: resp.question });
            const slot = document.getElementById('form-success-slot');
            if (slot !== null) slot.hidden = false;
          })
          .catch((err: unknown) => {
            submit.disabled = false;
            submit.textContent = 'Submit answer';
            if (err instanceof ApiError && err.code === 'QUESTION_ALREADY_ANSWERED_DIFFERENTLY') {
              load(qid)
                .then((resp) => {
                  populate(resp);
                  setAlertText(
                    'form-error-slot',
                    'Already answered',
                    'Another channel (or operator) recorded an answer first; the original is preserved.',
                  );
                })
                .catch((refetchErr: unknown) => {
                  renderError(refetchErr, 'topErrorSlot', 'Failed to refresh question');
                });
              return;
            }
            renderError(err, 'form-error-slot', 'Submit failed');
          });
      });
    };

    captureTokenFromUrl();

    const id = new URLSearchParams(window.location.search).get('id');

    if (id === null || id.length === 0) {
      const loading = document.getElementById('loading');
      if (loading !== null) loading.textContent = 'Missing ?id=<questionId> in URL.';
    } else if (getToken() === null) {
      const loading = document.getElementById('loading');
      if (loading !== null) {
        loading.textContent = 'No UI token present. Reopen the URL logged by factoryd.';
      }
    } else {
      const qid = id;
      load(qid)
        .then((resp) => {
          populate(resp);
          wireForm(qid);
        })
        .catch((err: unknown) => {
          const loading = document.getElementById('loading');
          if (err instanceof NoTokenError) {
            if (loading !== null) loading.textContent = err.message;
            return;
          }
          if (loading !== null) loading.hidden = true;
          renderError(err, 'topErrorSlot', 'Failed to load question');
        });
    }
  </script>
</Dashboard>
