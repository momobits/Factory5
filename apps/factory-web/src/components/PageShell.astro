---
/**
 * Per-page shell. `Dashboard.astro` owns the global chrome (header,
 * nav, page title from the `title` prop). `<PageShell>` is for pages
 * that want a sub-title + description block beneath the global title.
 * Many pages skip it entirely — Dashboard's `.page-title` is enough.
 */
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<header class="page-header">
  <h3>{title}</h3>
  {description !== undefined && <p class="page-description">{description}</p>}
</header>
<div class="page-body">
  <slot />
</div>

<style>
  .page-header {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 18px;
  }
  .page-header h3 {
    margin: 0;
    font-family: var(--f-display);
    font-style: italic;
    font-weight: 700;
    font-variation-settings: 'opsz' 36;
    font-size: 18px;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .page-description {
    margin: 0;
    color: var(--mute);
    font-size: 13px;
    max-width: 48rem;
    font-style: italic;
  }
  .page-body {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
</style>
