---
/**
 * `<form>` wrapper applying the dashboard's standard form CSS — grid
 * layout, max-width, focus rings. Use with `<Field>` and `<Submit>`
 * for the typical dashboard form. The default slot is the form's
 * fields + actions; the page's `<script>` wires the submit handler
 * (Astro components are server-rendered, so a button-driven submit
 * stays a client concern).
 *
 * `wide` removes the 38rem max-width for forms that need to span the
 * page (e.g., a CLAUDE.md textarea).
 *
 * Styling lives in Dashboard.astro's global stylesheet.
 */
interface Props {
  /** Optional `id` so a page script can `document.getElementById(id)` it. */
  id?: string;
  /** Optional native `action` URL — usually unused (we POST via apiPost). */
  action?: string;
  /** Native form method. Defaults to `POST`. */
  method?: 'get' | 'post' | 'GET' | 'POST';
  /** Drop the 38rem max-width (use full page width). */
  wide?: boolean;
}

const { id, action, method = 'POST', wide = false } = Astro.props;
---

<form
  class:list={['form', wide && 'wide']}
  id={id}
  action={action}
  method={method}
>
  <slot />
</form>
