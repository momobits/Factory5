---
/**
 * Submit / action button. `variant` picks the visual treatment:
 * - `primary` (default) — filled vermillion accent
 * - `default` — neutral outline
 * - `danger` — red outline (for cancel / delete actions)
 *
 * Always renders as `type="submit"`; for non-submit actions, use a
 * raw `<button>` directly — the form's submit semantics are why
 * this primitive exists.
 *
 * Visual treatment lives in Dashboard.astro's global `.btn` rules.
 */
interface Props {
  label: string;
  variant?: 'primary' | 'default' | 'danger';
  disabled?: boolean;
  /** Optional explicit `id` so a page script can re-label / re-disable. */
  id?: string;
}

const { label, variant = 'primary', disabled = false, id } = Astro.props;
---

<button
  type="submit"
  class:list={['btn', variant !== 'default' && `btn-${variant}`]}
  disabled={disabled}
  id={id}
>
  {label}
</button>
