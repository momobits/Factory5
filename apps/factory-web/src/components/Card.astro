---
/**
 * Single overview metric — title + numeric value, optional unit + trend
 * arrow. Lives inside `<div class="cards">` (a CSS grid) on dashboards
 * to render a row of stat cards. Replaces the inline `el('div',
 * { class: 'card' }, ...)` pattern threaded through every dashboard
 * page in `apps/factory-web/src/pages/`.
 */
interface Props {
  title: string;
  value: string | number;
  unit?: string;
  trend?: 'up' | 'down' | 'flat';
  href?: string;
  id?: string;
}

const { title, value, unit, trend, href, id } = Astro.props;

const trendArrow = trend === 'up' ? '↑' : trend === 'down' ? '↓' : trend === 'flat' ? '→' : null;
---

{
  href === undefined ? (
    <article class="card" id={id}>
      <h3>{title}</h3>
      <div class="value">
        {value}
        {unit !== undefined && <span class="unit">{unit}</span>}
        {trendArrow !== null && <span class={`trend trend--${trend}`}>{trendArrow}</span>}
      </div>
    </article>
  ) : (
    <a class="card card--link" href={href} id={id}>
      <h3>{title}</h3>
      <div class="value">
        {value}
        {unit !== undefined && <span class="unit">{unit}</span>}
        {trendArrow !== null && <span class={`trend trend--${trend}`}>{trendArrow}</span>}
      </div>
    </a>
  )
}

<!--
  Card visuals live in the global stylesheet (Dashboard.astro) so the
  letterpress border-left rule, vermillion hover state, and editorial
  numeral typography can be reused by pages that hand-roll `<div class="card">`
  markup. This file kept for the markup contract only.
-->
