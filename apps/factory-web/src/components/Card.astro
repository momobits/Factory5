---
/**
 * Single overview metric — title + numeric value, optional unit + trend
 * arrow. Lives inside `<div class="cards">` (a CSS grid) on dashboards
 * to render a row of stat cards. Replaces the inline `el('div',
 * { class: 'card' }, ...)` pattern threaded through every dashboard
 * page in `apps/factory-web/src/pages/`.
 */
interface Props {
  title: string;
  value: string | number;
  unit?: string;
  trend?: 'up' | 'down' | 'flat';
  href?: string;
}

const { title, value, unit, trend, href } = Astro.props;

const trendArrow = trend === 'up' ? '↑' : trend === 'down' ? '↓' : trend === 'flat' ? '→' : null;
---

{
  href === undefined ? (
    <article class="card">
      <h3>{title}</h3>
      <div class="value">
        {value}
        {unit !== undefined && <span class="unit">{unit}</span>}
        {trendArrow !== null && <span class={`trend trend--${trend}`}>{trendArrow}</span>}
      </div>
    </article>
  ) : (
    <a class="card card--link" href={href}>
      <h3>{title}</h3>
      <div class="value">
        {value}
        {unit !== undefined && <span class="unit">{unit}</span>}
        {trendArrow !== null && <span class={`trend trend--${trend}`}>{trendArrow}</span>}
      </div>
    </a>
  )
}

<style>
  .card {
    display: block;
    padding: 1rem;
    border: 1px solid color-mix(in srgb, currentColor 15%, transparent);
    border-radius: 6px;
    color: inherit;
    text-decoration: none;
  }
  .card--link {
    transition: background 0.12s ease-out;
  }
  .card--link:hover {
    background: color-mix(in srgb, currentColor 4%, transparent);
  }
  .card h3 {
    margin: 0 0 0.25rem 0;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: color-mix(in srgb, currentColor 70%, transparent);
  }
  .card .value {
    font-size: 1.75rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .card .unit {
    font-size: 0.95rem;
    font-weight: 400;
    color: color-mix(in srgb, currentColor 60%, transparent);
  }
  .card .trend {
    font-size: 0.95rem;
    font-weight: 500;
  }
  .card .trend--up {
    color: #22824d;
  }
  .card .trend--down {
    color: #c24;
  }
  .card .trend--flat {
    color: color-mix(in srgb, currentColor 55%, transparent);
  }
</style>
