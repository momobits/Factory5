---
/**
 * Status banner for inline messages. Three kinds — `info` (neutral),
 * `success` (green tint), `conflict` (red tint, for 4xx form errors
 * and conflicts). Title is required; `body` is optional; arbitrary
 * additional content (links, lists, code blocks) goes through the
 * default slot. Replaces the `el('div', { class: 'alert alert--…' })`
 * pattern in `pages/build.astro` etc.
 *
 * Visual treatment lives in Dashboard.astro's global stylesheet so the
 * banner reuses tokens (--signal / --hairline / etc.) and matches
 * `.alert` markup hand-rolled across pages.
 */
interface Props {
  kind: 'info' | 'success' | 'conflict';
  title: string;
  body?: string;
}

const { kind, title, body } = Astro.props;
---

<div class:list={['alert', `alert--${kind}`]} role={kind === 'conflict' ? 'alert' : 'status'}>
  <h4>{title}</h4>
  {body !== undefined && <p>{body}</p>}
  <slot />
</div>
