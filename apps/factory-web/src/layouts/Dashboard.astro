---
interface Props {
  title: string;
}
const { title } = Astro.props;

interface NavLink {
  href: string;
  label: string;
  num: string;
}
const navLinks: NavLink[] = [
  { href: '/app/', label: 'Overview', num: '01' },
  { href: '/app/projects/', label: 'Projects', num: '02' },
  { href: '/app/build', label: 'Build', num: '03' },
  { href: '/app/chat', label: 'Chat', num: '04' },
  { href: '/app/directives/', label: 'Directives', num: '05' },
  { href: '/app/questions/', label: 'Questions', num: '06' },
  { href: '/app/spend/', label: 'Spend', num: '07' },
  { href: '/app/findings/', label: 'Findings', num: '08' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — factory5 / Control Room</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,700;0,9..144,900;1,9..144,700;1,9..144,900&family=Bricolage+Grotesque:opsz,wght@12..96,300;12..96,400;12..96,500;12..96,700&family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      /* =================================================================
         FACTORY5 — EDITORIAL CONTROL ROOM (dual-theme)
         An editorial / mission-control aesthetic. Light = warm parchment,
         dark = ink-black. Vermillion signal accent persists across both.
         ================================================================= */

      :root {
        color-scheme: light dark;

        /* Type */
        --f-display: 'Fraunces', Georgia, 'Times New Roman', serif;
        --f-body: 'Bricolage Grotesque', system-ui, -apple-system, 'Segoe UI', sans-serif;
        --f-mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, Consolas, 'Liberation Mono', Menlo,
          monospace;
        --tracking-cap: 0.14em;

        /* Accents — kept across themes (vermillion / amber / status semantics) */
        --signal: #ff4d1c;
        --signal-2: #ff7a4e;
        --amber: #b87c1a;
        --acid: #2a8b54;
        --halt: #c0263a;
        --cool: #1f78bc;

        /* Light defaults (warm parchment) */
        --bg: #f4ecd9;
        --bg-2: #faf3e0;
        --surface: #fffaef;
        --surface-2: #f3e9d2;
        --ink: #1a1a1d;
        --ink-2: #353034;
        --mute: #6c6553;
        --mute-2: #948b78;
        --hairline: #d8cdb0;
        --hairline-2: #c0b69d;
        --grain-opacity: 0.22;
        --shadow-press: 0 1px 0 var(--hairline), 0 8px 24px -14px rgba(60, 40, 0, 0.18);
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --signal: #ff4d1c;
          --signal-2: #ff7a4e;
          --amber: #f0b65d;
          --acid: #9bd66b;
          --halt: #ff3e57;
          --cool: #6fc8ff;

          --bg: #0c0c0e;
          --bg-2: #131318;
          --surface: #16161a;
          --surface-2: #1f1f24;
          --ink: #f3ece0;
          --ink-2: #ddd3bf;
          --mute: #a39988;
          --mute-2: #6f6759;
          --hairline: #2b2b32;
          --hairline-2: #3a3a45;
          --grain-opacity: 0.5;
          --shadow-press: 0 1px 0 var(--hairline), 0 12px 32px -16px rgba(0, 0, 0, 0.6);
        }
      }

      * {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
      }
      body {
        font-family: var(--f-body);
        font-size: 14px;
        line-height: 1.55;
        font-feature-settings:
          'ss01',
          'cv11';
        position: relative;
        min-height: 100vh;
      }

      /* Paper grain + warm gradient atmosphere */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        background-image:
          radial-gradient(
            circle at 1px 1px,
            color-mix(in srgb, var(--ink) 4%, transparent) 1px,
            transparent 1.4px
          ),
          radial-gradient(
            ellipse 70vw 60vh at 80% -10%,
            color-mix(in srgb, var(--signal) 8%, transparent),
            transparent 60%
          ),
          radial-gradient(
            ellipse 60vw 50vh at -10% 110%,
            color-mix(in srgb, var(--amber) 8%, transparent),
            transparent 60%
          );
        background-size:
          22px 22px,
          100% 100%,
          100% 100%;
      }
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='180' height='180'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2'/><feColorMatrix values='0 0 0 0 0.95  0 0 0 0 0.92  0 0 0 0 0.86  0 0 0 0.05 0'/></filter><rect width='180' height='180' filter='url(%23n)'/></svg>");
        opacity: var(--grain-opacity);
        mix-blend-mode: overlay;
      }

      /* =================================================================
         MASTHEAD
         ================================================================= */
      header.shell {
        position: relative;
        z-index: 2;
        padding: 18px 32px 0;
        background: linear-gradient(
          180deg,
          var(--bg-2) 0%,
          color-mix(in srgb, var(--bg) 95%, transparent) 100%
        );
        border-bottom: 0;
      }
      .masthead-top {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
      }
      .brand {
        display: flex;
        align-items: baseline;
        gap: 8px;
        font-family: var(--f-display);
        font-weight: 900;
        font-size: clamp(2rem, 4vw, 3.2rem);
        font-variation-settings:
          'opsz' 144,
          'SOFT' 0;
        line-height: 0.9;
        letter-spacing: -0.03em;
        color: var(--ink);
      }
      .brand-mark {
        font-size: 0.65em;
        color: var(--signal);
        transform: translateY(-0.1em);
        font-style: italic;
        font-weight: 700;
      }
      .brand-italic {
        font-style: italic;
        font-weight: 400;
        font-size: 0.4em;
        color: var(--mute);
        letter-spacing: 0;
        font-variation-settings: 'opsz' 14;
      }
      .edition {
        font-family: var(--f-mono);
        font-size: 11px;
        text-align: right;
        color: var(--mute);
        text-transform: uppercase;
        letter-spacing: var(--tracking-cap);
      }
      .edition-label {
        display: block;
        opacity: 0.6;
        font-size: 10px;
      }
      .edition-value {
        color: var(--ink-2);
      }
      .masthead-rule {
        height: 0;
        margin: 6px 0 8px;
        border-top: 1px solid var(--ink);
        border-bottom: 1px solid var(--ink);
        padding: 1px 0;
      }
      .masthead-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        justify-content: space-between;
        padding-top: 4px;
      }
      header.shell nav.nav-inline {
        display: flex;
        gap: 22px;
        flex-wrap: wrap;
      }
      header.shell nav.nav-inline a {
        display: inline-flex;
        align-items: baseline;
        gap: 5px;
        color: var(--ink-2);
        text-decoration: none;
        font-family: var(--f-body);
        font-weight: 500;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: var(--tracking-cap);
        padding: 6px 0 8px;
        border-bottom: 1px solid transparent;
        transition:
          color 180ms ease,
          border-color 180ms ease;
      }
      header.shell nav.nav-inline a:hover {
        color: var(--ink);
        border-bottom-color: var(--signal);
      }
      header.shell nav.nav-inline a[aria-current='page'] {
        color: var(--ink);
        border-bottom-color: var(--signal);
      }
      header.shell nav.nav-inline a .nav-num {
        font-family: var(--f-mono);
        font-size: 9px;
        color: var(--signal);
        opacity: 0.9;
      }

      /* Header actions */
      .header-actions {
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .status-pip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-family: var(--f-mono);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: var(--tracking-cap);
        color: var(--mute);
        padding: 4px 10px;
        border: 1px solid var(--hairline);
        border-radius: 2px;
        background: var(--surface);
      }
      .pip-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--mute-2);
        flex-shrink: 0;
      }
      /* Status colors are theme-independent (intentional — operators recognize
         green/amber/red at a glance regardless of light/dark). */
      .status-pip[data-status='connected'] {
        color: #2a8b54;
        border-color: color-mix(in srgb, #2a8b54 50%, var(--hairline));
      }
      .status-pip[data-status='connected'] .pip-dot {
        background: #2a8b54;
        animation: pulse-pip 2.2s ease-in-out infinite;
      }
      .status-pip[data-status='reconnecting'] {
        color: #b87c1a;
        border-color: color-mix(in srgb, #b87c1a 40%, var(--hairline));
      }
      .status-pip[data-status='reconnecting'] .pip-dot {
        background: #b87c1a;
      }
      .status-pip[data-status='disconnected'] {
        color: #c0263a;
        border-color: color-mix(in srgb, #c0263a 40%, var(--hairline));
      }
      .status-pip[data-status='disconnected'] .pip-dot {
        background: #c0263a;
      }
      @keyframes pulse-pip {
        0%,
        100% {
          box-shadow: 0 0 0 0 color-mix(in srgb, #2a8b54 60%, transparent);
        }
        50% {
          box-shadow: 0 0 0 6px color-mix(in srgb, #2a8b54 0%, transparent);
        }
      }

      .btn-text {
        font: inherit;
        font-family: var(--f-body);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: var(--tracking-cap);
        padding: 6px 10px;
        background: transparent;
        border: 1px solid var(--hairline);
        color: var(--ink-2);
        cursor: pointer;
        border-radius: 2px;
        transition:
          color 180ms ease,
          border-color 180ms ease,
          background 180ms ease;
      }
      .btn-text:hover:not(:disabled) {
        background: var(--surface-2);
        color: var(--ink);
        border-color: var(--ink-2);
      }
      .btn-text:focus-visible {
        outline: 2px solid var(--signal);
        outline-offset: 2px;
      }

      /* Hamburger drawer (≤768px) */
      header.shell .nav-drawer {
        display: none;
      }
      header.shell .nav-drawer summary {
        list-style: none;
        cursor: pointer;
        padding: 0.5rem;
        border-radius: 2px;
        min-width: 44px;
        min-height: 44px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--hairline);
      }
      header.shell .nav-drawer summary::-webkit-details-marker {
        display: none;
      }
      header.shell .nav-drawer summary::marker {
        display: none;
        content: '';
      }
      header.shell .nav-drawer summary:hover,
      header.shell .nav-drawer[open] summary {
        background: var(--surface-2);
      }
      header.shell .nav-drawer summary:focus-visible {
        outline: 2px solid var(--signal);
        outline-offset: 2px;
      }
      header.shell .hamburger {
        display: inline-flex;
        flex-direction: column;
        justify-content: space-between;
        width: 18px;
        height: 14px;
      }
      header.shell .hamburger span {
        display: block;
        height: 2px;
        background: var(--ink);
        border-radius: 1px;
        transition:
          transform 120ms ease,
          opacity 120ms ease;
      }
      header.shell .nav-drawer[open] .hamburger span:nth-child(1) {
        transform: translateY(6px) rotate(45deg);
      }
      header.shell .nav-drawer[open] .hamburger span:nth-child(2) {
        opacity: 0;
      }
      header.shell .nav-drawer[open] .hamburger span:nth-child(3) {
        transform: translateY(-6px) rotate(-45deg);
      }
      header.shell .nav-drawer nav {
        position: absolute;
        top: 100%;
        right: 0;
        left: 0;
        display: flex;
        flex-direction: column;
        gap: 0;
        padding: 0.5rem 1.5rem 1rem;
        background: var(--bg-2);
        border-bottom: 1px solid var(--hairline);
        z-index: 10;
      }
      header.shell .nav-drawer nav a {
        padding: 0.7rem 0.5rem;
        font-size: 13px;
        color: var(--ink-2);
        text-decoration: none;
        border-bottom: 1px solid var(--hairline);
        font-family: var(--f-body);
        text-transform: uppercase;
        letter-spacing: var(--tracking-cap);
        font-weight: 500;
      }
      header.shell .nav-drawer nav a:hover {
        color: var(--ink);
      }
      header.shell .nav-drawer nav a .nav-num {
        font-family: var(--f-mono);
        font-size: 10px;
        color: var(--signal);
        margin-right: 6px;
      }
      .drawer-logout {
        margin-top: 0.5rem;
        text-align: left;
        padding: 0.7rem 0.5rem;
        border-top: 1px solid var(--hairline);
        border-radius: 0;
        font-size: 13px;
        width: 100%;
      }

      .logged-out-banner {
        margin-bottom: 1.25rem;
      }

      /* =================================================================
         PAGE
         ================================================================= */
      main.shell {
        position: relative;
        z-index: 1;
        padding: 28px 32px 80px;
        max-width: 80rem;
        margin: 0 auto;
      }
      .page-title {
        margin-bottom: 22px;
        padding-bottom: 14px;
        border-bottom: 1px solid var(--hairline);
      }
      .page-title h2 {
        margin: 0;
        font-family: var(--f-display);
        font-style: italic;
        font-weight: 700;
        font-variation-settings: 'opsz' 144;
        font-size: clamp(1.7rem, 2.6vw, 2.4rem);
        letter-spacing: -0.02em;
        color: var(--ink);
        line-height: 1.05;
      }
      .page-title h2::after {
        content: '';
        display: block;
        width: 36px;
        height: 2px;
        background: var(--signal);
        margin-top: 10px;
      }
      main.shell h2 {
        margin-top: 0;
      }
      main.shell h3 {
        font-family: var(--f-display);
        font-style: italic;
        font-weight: 700;
        font-variation-settings: 'opsz' 36;
        font-size: 18px;
        letter-spacing: -0.01em;
        margin: 22px 0 12px;
        color: var(--ink);
      }

      /* =================================================================
         RESPONSIVE
         ================================================================= */
      @media (max-width: 768px) {
        header.shell {
          padding: 14px 18px 0;
        }
        header.shell nav.nav-inline {
          display: none;
        }
        header.shell .nav-drawer {
          display: block;
        }
        .header-actions .pip-label,
        .header-actions .btn-logout {
          display: none;
        }
        main.shell {
          padding: 22px 18px 60px;
        }
      }
      @media (max-width: 640px) {
        form.form .form-row {
          grid-template-columns: 1fr;
        }
        .brand {
          font-size: 1.8rem;
        }
      }

      /* =================================================================
         SHARED PRIMITIVES
         (Dashboard's global style covers the things components don't own:
          cards grid, page-level helpers, table chrome, forms scaffolding,
          alerts. Component-scoped styles still exist alongside — they
          inherit the same tokens so the look stays cohesive.)
         ================================================================= */

      /* Cards grid */
      .cards {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(13rem, 1fr));
        gap: 14px;
        margin-bottom: 28px;
      }

      /* Card surface (legacy class — most pages use it directly) */
      .card {
        position: relative;
        display: block;
        padding: 18px 16px 16px;
        background: var(--surface);
        border: 1px solid var(--hairline);
        border-radius: 2px;
        color: var(--ink);
        text-decoration: none;
        overflow: hidden;
      }
      .card::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 2px;
        background: var(--hairline-2);
        transition:
          background 180ms ease,
          width 180ms ease;
      }
      a.card,
      .card--link {
        transition:
          transform 180ms ease,
          border-color 180ms ease,
          box-shadow 180ms ease;
      }
      a.card:hover,
      .card--link:hover {
        border-color: var(--ink-2);
        box-shadow: var(--shadow-press);
        transform: translateY(-1px);
      }
      a.card:hover::before,
      .card--link:hover::before {
        background: var(--signal);
        width: 3px;
      }
      .card h3 {
        margin: 0 0 8px;
        font-family: var(--f-body);
        font-weight: 700;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: var(--tracking-cap);
        color: var(--mute);
      }
      .card .value {
        font-family: var(--f-display);
        font-variation-settings: 'opsz' 72;
        font-weight: 900;
        font-size: 2rem;
        line-height: 1;
        color: var(--ink);
        font-variant-numeric: tabular-nums;
        display: flex;
        align-items: baseline;
        gap: 0.4rem;
        flex-wrap: wrap;
        letter-spacing: -0.02em;
      }
      .card .unit {
        font-family: var(--f-mono);
        font-size: 11px;
        font-weight: 400;
        color: var(--mute);
        text-transform: uppercase;
        letter-spacing: var(--tracking-cap);
      }
      .card .trend {
        font-size: 1rem;
        font-weight: 500;
      }
      .card .trend--up {
        color: #2a8b54;
      }
      .card .trend--down {
        color: #c0263a;
      }
      .card .trend--flat {
        color: var(--mute);
      }

      /* Tables */
      table {
        width: 100%;
        border-collapse: collapse;
        background: var(--surface);
        border: 1px solid var(--hairline);
        border-radius: 2px;
        overflow: hidden;
        font-family: var(--f-mono);
        font-size: 12px;
      }
      th,
      td {
        text-align: left;
        padding: 10px 14px;
        border-bottom: 1px solid var(--hairline);
        vertical-align: middle;
      }
      th {
        background: var(--surface-2);
        color: var(--mute);
        text-transform: uppercase;
        letter-spacing: var(--tracking-cap);
        font-size: 10px;
        font-weight: 500;
        font-family: var(--f-body);
      }
      tr:last-child td {
        border-bottom: 0;
      }
      tr:hover td {
        background: color-mix(in srgb, var(--signal) 4%, transparent);
      }
      td.num,
      th.num {
        text-align: right;
        font-variant-numeric: tabular-nums;
      }
      td a {
        color: var(--amber);
        text-decoration: none;
        border-bottom: 1px dotted var(--amber);
      }
      td a:hover {
        color: var(--ink);
        border-bottom-color: var(--ink);
      }
      .align-right {
        text-align: right;
      }
      .align-center {
        text-align: center;
      }

      /* Code */
      pre {
        padding: 14px 16px;
        background: var(--bg-2);
        border: 1px solid var(--hairline);
        border-radius: 2px;
        overflow-x: auto;
        font-family: var(--f-mono);
        font-size: 12px;
        line-height: 1.55;
        color: var(--ink-2);
      }
      code {
        font-family: var(--f-mono);
        font-size: 0.9em;
        background: var(--bg-2);
        padding: 1px 6px;
        border: 1px solid var(--hairline);
        border-radius: 2px;
        color: var(--amber);
      }
      pre code {
        background: transparent;
        border: 0;
        padding: 0;
        color: inherit;
      }

      /* States */
      .empty {
        color: var(--mute);
        font-style: italic;
        font-family: var(--f-mono);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: var(--tracking-cap);
        padding: 14px 16px;
        border: 1px dashed var(--hairline);
        border-radius: 2px;
        display: inline-block;
      }
      .err {
        color: #c0263a;
        font-family: var(--f-mono);
        font-size: 12px;
        padding: 10px 14px;
        border: 1px solid color-mix(in srgb, #c0263a 40%, var(--hairline));
        background: color-mix(in srgb, #c0263a 6%, var(--surface));
        border-radius: 2px;
      }

      /* Filter form */
      .filter-form {
        display: flex;
        gap: 10px;
        align-items: center;
        margin-bottom: 18px;
        flex-wrap: wrap;
        padding: 12px 14px;
        background: var(--surface);
        border: 1px solid var(--hairline);
        border-radius: 2px;
      }
      .filter-form label {
        font-family: var(--f-mono);
        font-size: 10px;
        color: var(--mute);
        text-transform: uppercase;
        letter-spacing: var(--tracking-cap);
      }
      .filter-form input,
      .filter-form select {
        font: inherit;
        font-family: var(--f-mono);
        font-size: 12px;
        padding: 6px 10px;
        background: var(--bg-2);
        color: var(--ink);
        border: 1px solid var(--hairline);
        border-radius: 2px;
        outline: none;
      }
      .filter-form input:focus,
      .filter-form select:focus {
        border-color: var(--signal);
      }
      .filter-form button {
        font: inherit;
        font-family: var(--f-body);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: var(--tracking-cap);
        padding: 6px 12px;
        background: var(--signal);
        color: var(--bg);
        border: 1px solid var(--signal);
        border-radius: 2px;
        cursor: pointer;
      }
      .filter-form button:hover:not(:disabled) {
        background: var(--ink);
        border-color: var(--ink);
        color: var(--bg);
      }
      .filter-form button[type='reset'],
      .filter-form .clear-btn {
        background: transparent;
        color: var(--ink-2);
        border-color: var(--hairline);
      }
      .filter-form button[type='reset']:hover,
      .filter-form .clear-btn:hover {
        background: var(--surface-2);
        color: var(--ink);
        border-color: var(--ink-2);
      }

      /* Form scaffolding (shared with Form.astro / Field.astro) */
      form.form {
        display: grid;
        gap: 14px;
        max-width: 38rem;
        margin-top: 14px;
      }
      form.form.wide {
        max-width: none;
      }
      .form-field {
        display: grid;
        gap: 4px;
      }
      .form-field label {
        font-family: var(--f-mono);
        font-size: 10px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: var(--tracking-cap);
        color: var(--mute);
      }
      .form-field .required {
        color: var(--signal);
        margin-left: 0.15rem;
      }
      .form-field input,
      .form-field select,
      .form-field textarea {
        font: inherit;
        font-family: var(--f-body);
        font-size: 13px;
        padding: 9px 12px;
        background: var(--bg-2);
        color: var(--ink);
        border: 1px solid var(--hairline);
        border-radius: 2px;
        color-scheme: inherit;
        transition: border-color 180ms ease;
      }
      .form-field input[type='number'] {
        font-variant-numeric: tabular-nums;
        font-family: var(--f-mono);
      }
      .form-field input:focus,
      .form-field select:focus,
      .form-field textarea:focus {
        outline: none;
        border-color: var(--signal);
        background: var(--surface);
      }
      .form-field textarea {
        min-height: 8rem;
        resize: vertical;
        font-family: var(--f-mono);
        font-size: 12.5px;
        line-height: 1.55;
      }
      .form-field .hint {
        font-family: var(--f-body);
        font-size: 11px;
        color: var(--mute);
        font-style: italic;
        margin: 0;
      }
      .form-row {
        display: grid;
        gap: 14px;
        grid-template-columns: 1fr 1fr;
      }
      .form-actions {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
        margin-top: 4px;
      }

      /* Buttons (shared with Submit.astro) */
      .btn {
        font: inherit;
        font-family: var(--f-body);
        font-weight: 500;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: var(--tracking-cap);
        padding: 9px 16px;
        background: transparent;
        color: var(--ink);
        border: 1px solid var(--hairline);
        border-radius: 2px;
        cursor: pointer;
        transition:
          background 180ms ease,
          color 180ms ease,
          border-color 180ms ease,
          transform 120ms ease;
      }
      .btn:hover:not(:disabled) {
        background: var(--surface-2);
        border-color: var(--ink-2);
      }
      .btn:active:not(:disabled) {
        transform: translateY(1px);
      }
      .btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
      }
      .btn-primary {
        background: var(--signal);
        color: var(--bg);
        border-color: var(--signal);
      }
      .btn-primary:hover:not(:disabled) {
        background: var(--ink);
        border-color: var(--ink);
        color: var(--bg);
        box-shadow: 0 6px 18px -8px color-mix(in srgb, var(--signal) 50%, transparent);
      }
      .btn-danger {
        border-color: color-mix(in srgb, #c0263a 50%, var(--hairline));
        color: #c0263a;
      }
      .btn-danger:hover:not(:disabled) {
        background: color-mix(in srgb, #c0263a 8%, var(--surface));
      }

      /* Cancel + Resume buttons (directive-detail title row + projects-row
         action). Tier 10 / 10.5. Both are JS-created at runtime so they
         live in the global stylesheet — Astro's scoped <style> attaches a
         data-astro-cid to template-emitted elements only, so runtime
         <button>s don't match scoped rules. */
      .cancel-btn,
      .directive-resume-btn,
      .row-resume-btn {
        font: inherit;
        font-size: 11px;
        font-family: var(--f-body);
        font-weight: 600;
        letter-spacing: var(--tracking-cap, 0.06em);
        text-transform: uppercase;
        padding: 6px 14px;
        border-radius: 999px;
        cursor: pointer;
        line-height: 1;
        transition:
          background 0.15s ease,
          border-color 0.15s ease,
          color 0.15s ease;
      }
      .cancel-btn {
        border: 1px solid color-mix(in srgb, #c0263a 55%, transparent);
        color: #c0263a;
        background: color-mix(in srgb, #c0263a 5%, transparent);
      }
      .cancel-btn:hover:not(:disabled) {
        background: color-mix(in srgb, #c0263a 14%, transparent);
        border-color: color-mix(in srgb, #c0263a 80%, transparent);
      }
      .cancel-btn:focus-visible {
        outline: 2px solid color-mix(in srgb, #c0263a 60%, transparent);
        outline-offset: 2px;
      }
      .cancel-btn:disabled {
        cursor: progress;
        color: color-mix(in srgb, #c0263a 55%, transparent);
        border-color: color-mix(in srgb, #c0263a 28%, transparent);
        background: color-mix(in srgb, #c0263a 3%, transparent);
      }
      .directive-resume-btn,
      .row-resume-btn {
        border: 1px solid color-mix(in srgb, var(--signal) 60%, transparent);
        color: var(--signal);
        background: color-mix(in srgb, var(--signal) 6%, transparent);
      }
      .directive-resume-btn:hover:not(:disabled),
      .row-resume-btn:hover:not(:disabled) {
        background: color-mix(in srgb, var(--signal) 16%, transparent);
        border-color: color-mix(in srgb, var(--signal) 85%, transparent);
      }
      .directive-resume-btn:focus-visible,
      .row-resume-btn:focus-visible {
        outline: 2px solid color-mix(in srgb, var(--signal) 60%, transparent);
        outline-offset: 2px;
      }
      .directive-resume-btn:disabled,
      .row-resume-btn:disabled {
        cursor: progress;
        color: color-mix(in srgb, var(--signal) 55%, transparent);
        border-color: color-mix(in srgb, var(--signal) 30%, transparent);
        background: color-mix(in srgb, var(--signal) 4%, transparent);
      }
      .row-resume-btn {
        font-size: 10px;
        padding: 4px 10px;
        margin-left: 10px;
      }

      /* Activity panel (Tier 10 / 10.6) — the directive-detail "Live log"
         section. Same scope rationale as the cancel/resume buttons above:
         lines are JS-created at runtime so the styling must live in the
         global stylesheet to reach them. */
      .log-tail {
        margin-top: 18px;
        position: relative;
        border: 1px solid var(--hairline);
        background: var(--bg-2);
        border-radius: 2px;
      }
      .log-tail-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        padding: 8px 14px;
        border-bottom: 1px solid var(--hairline);
        font-family: var(--f-body);
        font-size: 11px;
        letter-spacing: var(--tracking-cap, 0.06em);
        text-transform: uppercase;
        color: var(--ink-2);
      }
      .log-tail-count {
        color: var(--mute);
        font-family: var(--f-mono);
      }
      .log-tail-body {
        max-height: 22rem;
        overflow-y: auto;
        font-family: var(--f-mono);
        font-size: 12px;
        line-height: 1.5;
        padding: 8px 14px;
        background: var(--surface);
      }
      .log-tail-empty {
        padding: 14px;
        color: var(--mute);
        font-style: italic;
        text-align: center;
        font-family: var(--f-body);
      }
      .log-line {
        display: grid;
        grid-template-columns: auto 4rem auto 1fr;
        gap: 10px;
        padding: 3px 0;
        border-bottom: 1px dashed color-mix(in srgb, var(--hairline) 70%, transparent);
        align-items: baseline;
      }
      .log-line:last-child {
        border-bottom: none;
      }
      .log-ts {
        color: var(--mute);
        font-variant-numeric: tabular-nums;
        font-size: 10px;
      }
      .log-level {
        display: inline-flex;
        justify-content: center;
        padding: 1px 6px;
        border-radius: 2px;
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        font-family: var(--f-body);
        border: 1px solid transparent;
      }
      .log-level-info,
      .log-level-debug,
      .log-level-trace {
        color: var(--acid);
        background: color-mix(in srgb, var(--acid) 8%, transparent);
        border-color: color-mix(in srgb, var(--acid) 30%, transparent);
      }
      .log-level-warn {
        color: var(--amber);
        background: color-mix(in srgb, var(--amber) 10%, transparent);
        border-color: color-mix(in srgb, var(--amber) 40%, transparent);
      }
      .log-level-error,
      .log-level-fatal {
        color: var(--halt);
        background: color-mix(in srgb, var(--halt) 10%, transparent);
        border-color: color-mix(in srgb, var(--halt) 45%, transparent);
      }
      .log-component {
        color: var(--mute);
        font-size: 11px;
      }
      .log-msg {
        word-break: break-word;
        color: var(--ink);
      }
      /* Task-error follow-up row in the directive-detail tasks table
         (Tier 10 fix). Renders the worker's `result.error` string under
         the failed task row so the operator sees `error_max_turns` etc.
         without diving into the daemon log. */
      .task-error-row td.task-error-cell {
        padding: 6px 16px 10px 16px;
        background: color-mix(in srgb, var(--halt) 5%, transparent);
        border-bottom: 1px solid color-mix(in srgb, var(--halt) 20%, transparent);
        font-family: var(--f-mono);
        font-size: 11px;
        line-height: 1.45;
        color: var(--ink);
      }
      .task-error-row .task-error-label {
        display: inline-block;
        margin-right: 10px;
        padding: 1px 6px;
        border-radius: 2px;
        border: 1px solid color-mix(in srgb, var(--halt) 45%, transparent);
        background: color-mix(in srgb, var(--halt) 12%, transparent);
        color: var(--halt);
        font-family: var(--f-body);
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        vertical-align: baseline;
      }
      .task-error-row .task-error-msg {
        word-break: break-word;
      }
      /* Sticky "Resume tailing" button — appears inside the log-tail
         panel only when the operator has scrolled up, so live events
         that flow in don't yank them away from what they were reading. */
      .log-tail .log-resume-tail-btn {
        display: none;
        position: absolute;
        bottom: 10px;
        right: 12px;
        font: inherit;
        font-size: 11px;
        font-family: var(--f-body);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: var(--tracking-cap, 0.06em);
        padding: 4px 10px;
        border-radius: 999px;
        border: 1px solid color-mix(in srgb, var(--signal) 50%, transparent);
        background: var(--surface);
        color: var(--signal);
        cursor: pointer;
        box-shadow: 0 1px 4px color-mix(in srgb, var(--ink) 12%, transparent);
      }
      .log-tail.paused .log-resume-tail-btn {
        display: block;
      }

      /* Transcript panel (Tier 15.13) — expandable per-task conversation
         viewer inside the directive-detail tasks table. All elements are
         JS-created at runtime so the styling MUST live in the global
         stylesheet (same rationale as cancel/resume/log-tail above). */
      .task-row {
        cursor: pointer;
        transition: background 0.12s ease;
      }
      .task-row:hover td {
        background: color-mix(in srgb, var(--signal) 6%, transparent);
      }
      .task-row--expanded td {
        background: color-mix(in srgb, var(--signal) 8%, transparent);
        border-bottom-color: color-mix(in srgb, var(--signal) 25%, transparent);
      }
      .transcript-panel-row td.transcript-panel-cell {
        padding: 0;
        background: var(--bg-2);
      }
      .transcript-panel-row:hover td {
        background: var(--bg-2);
      }
      .transcript-panel {
        border-top: 2px solid var(--signal);
      }
      .transcript-tabs {
        display: flex;
        align-items: center;
        gap: 0;
        padding: 0 14px;
        background: var(--surface-2);
        border-bottom: 1px solid var(--hairline);
      }
      .transcript-tab {
        font: inherit;
        font-family: var(--f-body);
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: var(--tracking-cap, 0.06em);
        padding: 8px 14px;
        background: transparent;
        border: none;
        border-bottom: 2px solid transparent;
        color: var(--mute);
        cursor: pointer;
        transition: color 0.15s ease, border-color 0.15s ease;
      }
      .transcript-tab:hover {
        color: var(--ink);
      }
      .transcript-tab--active {
        color: var(--signal);
        border-bottom-color: var(--signal);
        font-weight: 600;
      }
      .transcript-live-badge {
        font-family: var(--f-mono);
        font-size: 10px;
        color: var(--acid);
        margin-left: auto;
        padding: 4px 8px;
        animation: live-pip-blink 0.9s ease-in-out infinite;
      }
      .transcript-count {
        font-family: var(--f-mono);
        font-size: 10px;
        color: var(--mute);
        margin-left: auto;
        padding: 4px 8px;
      }
      .transcript-body {
        max-height: 28rem;
        overflow-y: auto;
        padding: 10px 14px;
        font-family: var(--f-mono);
        font-size: 12px;
        line-height: 1.5;
        background: var(--surface);
      }
      .transcript-loading,
      .transcript-empty {
        padding: 14px;
        color: var(--mute);
        font-style: italic;
        text-align: center;
        font-family: var(--f-body);
      }
      .transcript-error {
        padding: 10px 14px;
        color: var(--halt);
        font-family: var(--f-mono);
        font-size: 12px;
      }
      .transcript-line {
        padding: 6px 0;
        border-bottom: 1px dashed color-mix(in srgb, var(--hairline) 60%, transparent);
      }
      .transcript-line:last-child {
        border-bottom: none;
      }
      .transcript-type-badge {
        display: inline-block;
        padding: 1px 6px;
        border-radius: 2px;
        font-family: var(--f-body);
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin-bottom: 4px;
        border: 1px solid var(--hairline);
        color: var(--mute);
        background: color-mix(in srgb, var(--mute) 6%, transparent);
      }
      .transcript-type--assistant {
        color: var(--cool);
        border-color: color-mix(in srgb, var(--cool) 40%, transparent);
        background: color-mix(in srgb, var(--cool) 8%, transparent);
      }
      .transcript-type--tool-use {
        color: var(--amber);
        border-color: color-mix(in srgb, var(--amber) 40%, transparent);
        background: color-mix(in srgb, var(--amber) 8%, transparent);
      }
      .transcript-type--tool-result {
        color: var(--acid);
        border-color: color-mix(in srgb, var(--acid) 30%, transparent);
        background: color-mix(in srgb, var(--acid) 6%, transparent);
      }
      .transcript-type--error {
        color: var(--halt);
        border-color: color-mix(in srgb, var(--halt) 45%, transparent);
        background: color-mix(in srgb, var(--halt) 10%, transparent);
      }
      .transcript-type--result {
        color: var(--ink-2);
        border-color: var(--hairline-2);
        background: color-mix(in srgb, var(--ink) 4%, transparent);
      }
      .transcript-type--thinking {
        color: var(--mute);
        border-style: dashed;
      }
      .transcript-type--user {
        color: var(--signal);
        border-color: color-mix(in srgb, var(--signal) 35%, transparent);
        background: color-mix(in srgb, var(--signal) 6%, transparent);
      }
      .transcript-type--system,
      .transcript-type--muted {
        color: var(--mute);
        opacity: 0.85;
      }
      .transcript-meta {
        display: inline-block;
        margin-left: 8px;
        font-family: var(--f-mono);
        font-size: 10px;
        color: var(--mute);
      }
      .transcript-collapsed,
      .transcript-thinking,
      .transcript-system {
        margin-top: 4px;
      }
      .transcript-collapsed > summary,
      .transcript-thinking > summary,
      .transcript-system > summary {
        cursor: pointer;
        font-family: var(--f-body);
        font-size: 11px;
        color: var(--mute);
        list-style: none;
        padding: 2px 0;
        user-select: none;
      }
      .transcript-collapsed > summary::-webkit-details-marker,
      .transcript-thinking > summary::-webkit-details-marker,
      .transcript-system > summary::-webkit-details-marker {
        display: none;
      }
      .transcript-collapsed > summary::before,
      .transcript-thinking > summary::before,
      .transcript-system > summary::before {
        content: '▸ ';
        color: var(--mute);
        font-size: 9px;
      }
      .transcript-collapsed[open] > summary::before,
      .transcript-thinking[open] > summary::before,
      .transcript-system[open] > summary::before {
        content: '▾ ';
      }
      .transcript-text--muted {
        color: var(--mute);
        opacity: 0.85;
      }
      .transcript-line--muted {
        opacity: 0.6;
        padding: 2px 0;
      }
      .transcript-line--muted .transcript-type-badge {
        margin-bottom: 0;
      }
      .transcript-line--system {
        opacity: 0.7;
      }
      .transcript-text {
        margin: 4px 0 0;
        padding: 8px 10px;
        font-family: var(--f-body);
        font-size: 13px;
        line-height: 1.55;
        white-space: pre-wrap;
        word-break: break-word;
        background: var(--bg-2);
        border: 1px solid var(--hairline);
        border-radius: 2px;
        color: var(--ink);
      }
      .transcript-code {
        margin: 4px 0 0;
        padding: 6px 10px;
        font-family: var(--f-mono);
        font-size: 11px;
        line-height: 1.45;
        white-space: pre-wrap;
        word-break: break-word;
        background: var(--bg-2);
        border: 1px solid var(--hairline);
        border-radius: 2px;
        color: var(--ink-2);
        max-height: 12rem;
        overflow-y: auto;
      }
      .transcript-load-more {
        display: block;
        width: 100%;
        font: inherit;
        font-family: var(--f-body);
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: var(--tracking-cap, 0.06em);
        padding: 8px 14px;
        background: var(--surface-2);
        border: none;
        border-top: 1px solid var(--hairline);
        color: var(--signal);
        cursor: pointer;
        transition: background 0.15s ease, color 0.15s ease;
      }
      .transcript-load-more:hover {
        background: color-mix(in srgb, var(--signal) 10%, var(--surface-2));
      }
      .transcript-retry-row {
        display: flex;
        gap: 10px;
        padding: 10px 14px;
        background: var(--surface-2);
        border-top: 1px solid var(--hairline);
      }
      .transcript-retry-btn {
        font: inherit;
        font-family: var(--f-body);
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: var(--tracking-cap, 0.06em);
        padding: 6px 14px;
        border-radius: 999px;
        cursor: pointer;
        line-height: 1;
        transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
      }
      .transcript-retry--resume {
        border: 1px solid color-mix(in srgb, var(--signal) 60%, transparent);
        color: var(--signal);
        background: color-mix(in srgb, var(--signal) 6%, transparent);
      }
      .transcript-retry--resume:hover:not(:disabled) {
        background: color-mix(in srgb, var(--signal) 16%, transparent);
        border-color: color-mix(in srgb, var(--signal) 85%, transparent);
      }
      .transcript-retry--clean {
        border: 1px solid color-mix(in srgb, var(--halt) 50%, transparent);
        color: var(--halt);
        background: color-mix(in srgb, var(--halt) 5%, transparent);
      }
      .transcript-retry--clean:hover:not(:disabled) {
        background: color-mix(in srgb, var(--halt) 14%, transparent);
        border-color: color-mix(in srgb, var(--halt) 80%, transparent);
      }
      .transcript-retry-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
      }
      .transcript-retry-btn:focus-visible {
        outline: 2px solid var(--signal);
        outline-offset: 2px;
      }
      .transcript-retry-error {
        margin: 0;
        font-size: 0.75rem;
      }

      /* Alerts */
      .alert {
        padding: 14px 18px;
        border-radius: 2px;
        border: 1px solid var(--hairline);
        background: var(--surface);
        font-size: 13px;
        max-width: 42rem;
        position: relative;
        font-family: var(--f-body);
      }
      .alert h4 {
        margin: 0 0 4px 0;
        font-family: var(--f-display);
        font-variation-settings: 'opsz' 36;
        font-style: italic;
        font-weight: 700;
        font-size: 16px;
        letter-spacing: -0.01em;
      }
      .alert p {
        margin: 4px 0;
        color: var(--ink-2);
      }
      .alert pre {
        margin: 8px 0 0 0;
        padding: 10px 12px;
        font-size: 11px;
      }
      .alert--conflict {
        border-color: color-mix(in srgb, #c0263a 50%, var(--hairline));
        background: color-mix(in srgb, #c0263a 6%, var(--surface));
      }
      .alert--conflict h4 {
        color: #c0263a;
      }
      .alert--success {
        border-color: color-mix(in srgb, #2a8b54 50%, var(--hairline));
        background: color-mix(in srgb, #2a8b54 6%, var(--surface));
      }
      .alert--success h4 {
        color: #2a8b54;
      }
      .alert--info {
        border-color: var(--hairline);
        background: var(--surface);
      }

      /* Links */
      a.link,
      a[class~='link'] {
        color: var(--amber);
        text-decoration: none;
        border-bottom: 1px dotted var(--amber);
      }
      a.link:hover {
        color: var(--ink);
        border-bottom-color: var(--ink);
      }

      /* Focus */
      :focus-visible {
        outline: 2px solid var(--signal);
        outline-offset: 2px;
      }

      /* Scrollbars */
      *::-webkit-scrollbar {
        width: 10px;
        height: 10px;
      }
      *::-webkit-scrollbar-track {
        background: transparent;
      }
      *::-webkit-scrollbar-thumb {
        background: var(--hairline-2);
        border: 2px solid var(--bg);
        border-radius: 6px;
      }
      *::-webkit-scrollbar-thumb:hover {
        background: var(--mute-2);
      }

      /* Structured findings (Tier 15.13) — rich description cells in the
         findings list. All cells are JS-created at runtime so the styling
         MUST live in the global stylesheet. */
      .finding-structured { display: flex; flex-direction: column; gap: 4px; }
      .finding-title { font-weight: 600; font-size: 13px; line-height: 1.3; }
      .finding-meta { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
      .finding-category {
        font-family: var(--f-body);
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 1px 6px;
        border: 1px solid var(--hairline);
        border-radius: 2px;
        color: var(--mute);
      }
      .finding-autofix {
        font-family: var(--f-body);
        font-size: 10px;
        color: var(--acid);
        border: 1px solid color-mix(in srgb, var(--acid) 40%, transparent);
        padding: 1px 6px;
        border-radius: 2px;
      }
      .finding-location {
        font-family: var(--f-mono);
        font-size: 11px;
        color: var(--mute);
      }
      .finding-why, .finding-fix {
        font-size: 12px;
        line-height: 1.4;
        color: var(--mute);
      }
      /* Tier 15.13 — abandoned worktrees panel on directive detail */
      .abandoned-panel {
        margin-top: 24px;
        padding: 16px;
        border: 1px solid var(--hairline);
        border-radius: 4px;
        background: color-mix(in srgb, var(--mute) 6%, transparent);
      }
      .abandoned-panel h3 {
        margin: 0 0 8px 0;
        font-size: 14px;
        font-weight: 600;
      }
      .abandoned-hint {
        margin: 0 0 12px 0;
        font-size: 12px;
        color: var(--mute);
        line-height: 1.4;
      }
      .abandoned-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .abandoned-item {
        font-family: var(--f-mono);
        font-size: 12px;
        padding: 2px 0;
        color: var(--ink);
      }
      .abandoned-task-id {
        font-weight: 600;
      }
      .abandoned-date {
        color: var(--mute);
      }
    </style>
  </head>
  <body>
    <header class="shell">
      <div class="masthead-top">
        <div class="brand">
          <span class="brand-mark" aria-hidden="true">§</span>
          <span class="brand-name">factory5</span>
          <span class="brand-italic">&nbsp;/ Control Room</span>
        </div>
        <div class="edition">
          <span class="edition-label">Edition</span>
          <span class="edition-value">Vol. V · {title}</span>
        </div>
      </div>
      <div class="masthead-rule"></div>
      <div class="masthead-meta">
        <nav class="nav-inline">
          {
            navLinks.map((link) => (
              <a
                href={link.href}
                aria-current={Astro.url.pathname === link.href ? 'page' : undefined}
              >
                <span class="nav-num">{link.num}</span>
                <span>{link.label}</span>
              </a>
            ))
          }
        </nav>
        <div class="header-actions">
          <span class="status-pip" id="status-pip" data-status="reconnecting" aria-live="polite">
            <span class="pip-dot" aria-hidden="true"></span>
            <span class="pip-label">Tuning…</span>
          </span>
          <button type="button" class="btn-text btn-logout" data-logout>Sign out</button>
          <details class="nav-drawer">
            <summary aria-label="Navigation">
              <span class="hamburger" aria-hidden="true">
                <span></span><span></span><span></span>
              </span>
            </summary>
            <nav>
              {
                navLinks.map((link) => (
                  <a
                    href={link.href}
                    aria-current={Astro.url.pathname === link.href ? 'page' : undefined}
                  >
                    <span class="nav-num">{link.num}</span>
                    {link.label}
                  </a>
                ))
              }
              <button type="button" class="btn-text drawer-logout" data-logout>
                Sign out
              </button>
            </nav>
          </details>
        </div>
      </div>
    </header>
    <main class="shell">
      <div class="logged-out-banner alert alert--info" id="logged-out-banner" hidden>
        <h4>Signed out</h4>
        <p>Reopen the URL logged by factoryd to sign in.</p>
      </div>
      <header class="page-title">
        <h2>{title}</h2>
      </header>
      <slot />
    </main>
    <script>
      import {
        apiFetch,
        ApiError,
        captureTokenFromUrl,
        clearToken,
        getToken,
        NoTokenError,
      } from '../lib/api';

      // Idempotent — page-level scripts also call this; whichever runs first wins.
      captureTokenFromUrl();

      // Logged-out banner: show on `?logged-out=1`, then strip the param so a
      // refresh doesn't keep replaying the banner.
      {
        const params = new URLSearchParams(window.location.search);
        if (params.get('logged-out') === '1') {
          const banner = document.getElementById('logged-out-banner');
          if (banner !== null) banner.hidden = false;
          params.delete('logged-out');
          const query = params.toString();
          const newUrl =
            window.location.pathname +
            (query.length > 0 ? `?${query}` : '') +
            window.location.hash;
          window.history.replaceState({}, '', newUrl);
        }
      }

      // Logout — single handler wired to every [data-logout] button (desktop
      // header + mobile drawer share the click target).
      for (const btn of document.querySelectorAll<HTMLButtonElement>('[data-logout]')) {
        btn.addEventListener('click', () => {
          clearToken();
          window.location.href = '/app/?logged-out=1';
        });
      }

      // Connection-status heartbeat — poll /api/v1/status every 30s.
      // 0 failures → green Connected; 1-2 → amber Reconnecting;
      // 3+ consecutive → red Disconnected. No-token jumps straight to red
      // labelled "Signed out" so the post-logout state reads honestly.
      const POLL_INTERVAL_MS = 30_000;
      const FAILURE_THRESHOLD = 3;

      type PipState = 'connected' | 'reconnecting' | 'disconnected';

      let consecutiveFailures = 0;

      const setStatus = (state: PipState, label: string, hover?: string): void => {
        const pip = document.getElementById('status-pip');
        if (pip === null) return;
        pip.dataset.status = state;
        pip.title = hover ?? label;
        const labelEl = pip.querySelector('.pip-label');
        if (labelEl !== null) labelEl.textContent = label;
      };

      const tick = async (): Promise<void> => {
        if (getToken() === null) {
          consecutiveFailures = FAILURE_THRESHOLD;
          setStatus('disconnected', 'Signed out');
          return;
        }
        try {
          await apiFetch('/api/v1/status');
          consecutiveFailures = 0;
          setStatus('connected', 'Live');
        } catch (err) {
          if (err instanceof NoTokenError) {
            setStatus('disconnected', 'Signed out');
            return;
          }
          // 401 means the stored token is stale (commonly: daemon restart
          // rotated the token, or the operator was signed out elsewhere).
          // Polling won't recover this — short-circuit to a label that tells
          // the operator what to do instead of cycling through "Reconnecting".
          if (err instanceof ApiError && err.status === 401) {
            consecutiveFailures = FAILURE_THRESHOLD;
            setStatus(
              'disconnected',
              'Session expired',
              'Daemon restarted — run `factory ui-token` for a fresh URL (or paste a new URL from the daemon stdout).',
            );
            return;
          }
          consecutiveFailures++;
          if (consecutiveFailures >= FAILURE_THRESHOLD) {
            setStatus('disconnected', 'Disconnected');
          } else {
            setStatus('reconnecting', 'Reconnecting…');
          }
        }
      };

      void tick();
      window.setInterval(() => void tick(), POLL_INTERVAL_MS);
    </script>
  </body>
</html>
