---
interface Props {
  title: string;
}
const { title } = Astro.props;

interface NavLink {
  href: string;
  label: string;
}
const navLinks: NavLink[] = [
  { href: '/app/', label: 'Overview' },
  { href: '/app/projects/', label: 'Projects' },
  { href: '/app/build', label: 'Build' },
  { href: '/app/chat', label: 'Chat' },
  { href: '/app/directives/', label: 'Directives' },
  { href: '/app/questions/', label: 'Questions' },
  { href: '/app/spend/', label: 'Spend' },
  { href: '/app/findings/', label: 'Findings' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — factory5</title>
    <style>
      :root {
        color-scheme: light dark;
        font-family:
          system-ui,
          -apple-system,
          Segoe UI,
          Roboto,
          sans-serif;
      }
      body {
        margin: 0;
        padding: 0;
      }
      header.shell {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding: 0.75rem 1.5rem;
        border-bottom: 1px solid color-mix(in srgb, currentColor 15%, transparent);
        position: relative;
      }
      header.shell h1 {
        margin: 0;
        font-size: 1rem;
        font-weight: 600;
        flex-shrink: 0;
      }
      header.shell nav {
        display: flex;
        gap: 1rem;
      }
      header.shell nav a {
        color: inherit;
        text-decoration: none;
        font-size: 0.9rem;
        padding: 0.25rem 0.5rem;
        border-radius: 3px;
      }
      header.shell nav a[aria-current='page'],
      header.shell nav a:hover {
        background: color-mix(in srgb, currentColor 10%, transparent);
      }
      header.shell nav.nav-inline {
        flex-wrap: wrap;
      }
      /* Hamburger drawer — visible only at ≤768px (see media query below).
         Uses native <details>/<summary> so toggle is keyboard-accessible
         and screen-reader-friendly without JS. The drawer auto-closes on
         link click because each click navigates to a fresh page. */
      .header-actions {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-left: auto;
      }
      .status-pip {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.85rem;
        color: color-mix(in srgb, currentColor 70%, transparent);
      }
      .pip-dot {
        display: inline-block;
        width: 0.55rem;
        height: 0.55rem;
        border-radius: 50%;
        background: color-mix(in srgb, currentColor 50%, transparent);
        flex-shrink: 0;
      }
      /* Status colors are intentional and theme-independent — operators
         need at-a-glance recognition of green/amber/red regardless of
         light/dark. Mid-luminance shades read on both themes. */
      .status-pip[data-status='connected'] .pip-dot {
        background: #2a8;
        box-shadow: 0 0 0 2px color-mix(in srgb, #2a8 25%, transparent);
      }
      .status-pip[data-status='reconnecting'] .pip-dot {
        background: #d80;
        box-shadow: 0 0 0 2px color-mix(in srgb, #d80 25%, transparent);
      }
      .status-pip[data-status='disconnected'] .pip-dot {
        background: #c24;
        box-shadow: 0 0 0 2px color-mix(in srgb, #c24 25%, transparent);
      }
      .btn-text {
        font: inherit;
        font-size: 0.85rem;
        padding: 0.25rem 0.5rem;
        background: transparent;
        border: 1px solid transparent;
        color: inherit;
        cursor: pointer;
        border-radius: 3px;
      }
      .btn-text:hover:not(:disabled) {
        background: color-mix(in srgb, currentColor 10%, transparent);
      }
      .btn-text:focus-visible {
        outline: 2px solid color-mix(in srgb, currentColor 30%, transparent);
        outline-offset: 1px;
      }
      .drawer-logout {
        margin-top: 0.5rem;
        text-align: left;
        padding: 0.6rem 0.5rem;
        border-top: 1px solid color-mix(in srgb, currentColor 12%, transparent);
        border-radius: 0;
        font-size: 0.95rem;
        width: 100%;
      }
      .logged-out-banner {
        margin-bottom: 1.25rem;
      }
      header.shell .nav-drawer {
        display: none;
      }
      header.shell .nav-drawer summary {
        list-style: none;
        cursor: pointer;
        padding: 0.5rem;
        border-radius: 3px;
        /* Generous tap target — 44×44 per Apple HIG.
           Three 2px bars + 5px gaps = 16px tall icon centered in a ~44px box. */
        min-width: 44px;
        min-height: 44px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }
      header.shell .nav-drawer summary::-webkit-details-marker {
        display: none;
      }
      header.shell .nav-drawer summary::marker {
        display: none;
        content: '';
      }
      header.shell .nav-drawer summary:hover,
      header.shell .nav-drawer[open] summary {
        background: color-mix(in srgb, currentColor 10%, transparent);
      }
      header.shell .nav-drawer summary:focus-visible {
        outline: 2px solid color-mix(in srgb, currentColor 40%, transparent);
        outline-offset: 2px;
      }
      header.shell .hamburger {
        display: inline-flex;
        flex-direction: column;
        justify-content: space-between;
        width: 18px;
        height: 14px;
      }
      header.shell .hamburger span {
        display: block;
        height: 2px;
        background: currentColor;
        border-radius: 1px;
      }
      header.shell .nav-drawer[open] .hamburger span:nth-child(1) {
        transform: translateY(6px) rotate(45deg);
      }
      header.shell .nav-drawer[open] .hamburger span:nth-child(2) {
        opacity: 0;
      }
      header.shell .nav-drawer[open] .hamburger span:nth-child(3) {
        transform: translateY(-6px) rotate(-45deg);
      }
      header.shell .hamburger span {
        transition:
          transform 120ms ease,
          opacity 120ms ease;
      }
      header.shell .nav-drawer nav {
        position: absolute;
        top: 100%;
        right: 0;
        left: 0;
        flex-direction: column;
        gap: 0;
        padding: 0.5rem 1.5rem 1rem;
        background: Canvas;
        border-bottom: 1px solid color-mix(in srgb, currentColor 15%, transparent);
        z-index: 10;
      }
      header.shell .nav-drawer nav a {
        padding: 0.6rem 0.5rem;
        font-size: 0.95rem;
        border-radius: 4px;
      }
      main.shell {
        padding: 1.5rem;
        max-width: 72rem;
        margin: 0 auto;
      }
      @media (max-width: 768px) {
        header.shell {
          padding: 0.5rem 1rem;
          gap: 0.75rem;
        }
        header.shell nav.nav-inline {
          display: none;
        }
        header.shell .nav-drawer {
          display: block;
        }
        .header-actions .pip-label,
        .header-actions .btn-logout {
          display: none;
        }
        main.shell {
          padding: 1rem;
        }
      }
      @media (max-width: 640px) {
        form.form .form-row {
          grid-template-columns: 1fr;
        }
      }
      main.shell h2 {
        margin-top: 0;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
      }
      th,
      td {
        text-align: left;
        padding: 0.4rem 0.6rem;
        border-bottom: 1px solid color-mix(in srgb, currentColor 10%, transparent);
      }
      th {
        font-weight: 600;
        background: color-mix(in srgb, currentColor 4%, transparent);
      }
      td.num {
        text-align: right;
        font-variant-numeric: tabular-nums;
      }
      pre {
        padding: 0.75rem 1rem;
        background: color-mix(in srgb, currentColor 6%, transparent);
        border-radius: 4px;
        overflow-x: auto;
      }
      .empty {
        color: color-mix(in srgb, currentColor 60%, transparent);
        font-style: italic;
      }
      .err {
        color: #c24;
      }
      .filter-form {
        display: flex;
        gap: 0.5rem;
        align-items: center;
        margin-bottom: 1rem;
        flex-wrap: wrap;
      }
      .filter-form label {
        font-size: 0.85rem;
      }
      .cards {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(12rem, 1fr));
        gap: 1rem;
      }
      .card {
        padding: 1rem;
        border: 1px solid color-mix(in srgb, currentColor 15%, transparent);
        border-radius: 6px;
      }
      .card h3 {
        margin: 0 0 0.25rem 0;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: color-mix(in srgb, currentColor 70%, transparent);
      }
      .card .value {
        font-size: 1.75rem;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
      }
      a.link {
        color: inherit;
      }

      /* Form primitives — added in 11.5 (ADR 0027). Uses the same
         color-mix(currentColor) palette as the rest of the dashboard so
         every input/button auto-adapts to light/dark via color-scheme. */
      form.form {
        display: grid;
        gap: 1rem;
        max-width: 36rem;
        margin-top: 1rem;
      }
      form.form.wide {
        max-width: none;
      }
      .form-field {
        display: grid;
        gap: 0.25rem;
      }
      .form-field label {
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.01em;
      }
      .form-field input,
      .form-field select,
      .form-field textarea {
        font: inherit;
        font-size: 0.9rem;
        padding: 0.45rem 0.6rem;
        border: 1px solid color-mix(in srgb, currentColor 20%, transparent);
        border-radius: 4px;
        background: color-mix(in srgb, currentColor 3%, transparent);
        color: inherit;
        color-scheme: inherit;
      }
      .form-field input[type='number'] {
        font-variant-numeric: tabular-nums;
      }
      .form-field input:focus,
      .form-field select:focus,
      .form-field textarea:focus {
        outline: 2px solid color-mix(in srgb, currentColor 30%, transparent);
        outline-offset: -1px;
        background: color-mix(in srgb, currentColor 5%, transparent);
      }
      .form-field textarea {
        min-height: 7rem;
        resize: vertical;
        font-family: ui-monospace, SFMono-Regular, Consolas, 'Liberation Mono', Menlo, monospace;
        line-height: 1.45;
      }
      .form-field .hint {
        font-size: 0.8rem;
        color: color-mix(in srgb, currentColor 60%, transparent);
      }
      .form-row {
        display: grid;
        gap: 1rem;
        grid-template-columns: 1fr 1fr;
      }
      .form-actions {
        display: flex;
        gap: 0.75rem;
        align-items: center;
        flex-wrap: wrap;
      }
      .btn {
        font: inherit;
        font-size: 0.9rem;
        padding: 0.45rem 1rem;
        border: 1px solid color-mix(in srgb, currentColor 25%, transparent);
        border-radius: 4px;
        background: color-mix(in srgb, currentColor 4%, transparent);
        color: inherit;
        cursor: pointer;
      }
      .btn:hover:not(:disabled) {
        background: color-mix(in srgb, currentColor 10%, transparent);
      }
      .btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
      }
      .btn-primary {
        /* CanvasText, not currentColor: `color: Canvas` rebinds currentColor
           to Canvas, collapsing background and text to the same colour.
           CanvasText is the system pair to Canvas, guaranteed to contrast. */
        background: color-mix(in srgb, CanvasText 85%, transparent);
        color: Canvas;
        border-color: transparent;
      }
      .btn-primary:hover:not(:disabled) {
        background: color-mix(in srgb, CanvasText 95%, transparent);
      }
      .btn-danger {
        border-color: color-mix(in srgb, #c24 50%, transparent);
        color: #c24;
      }
      .btn-danger:hover:not(:disabled) {
        background: color-mix(in srgb, #c24 8%, transparent);
      }
      .alert {
        padding: 0.75rem 1rem;
        border-radius: 4px;
        border: 1px solid color-mix(in srgb, currentColor 18%, transparent);
        background: color-mix(in srgb, currentColor 5%, transparent);
        font-size: 0.9rem;
        max-width: 36rem;
      }
      .alert h4 {
        margin: 0 0 0.25rem 0;
        font-size: 0.95rem;
      }
      .alert p {
        margin: 0.25rem 0;
      }
      .alert pre {
        margin: 0.5rem 0 0 0;
        padding: 0.5rem 0.75rem;
        font-size: 0.85rem;
      }
      .alert--conflict {
        border-color: color-mix(in srgb, #c24 50%, transparent);
        background: color-mix(in srgb, #c24 8%, transparent);
      }
      .alert--success {
        border-color: color-mix(in srgb, #2a8 55%, transparent);
        background: color-mix(in srgb, #2a8 8%, transparent);
      }
      .alert--info {
        border-color: color-mix(in srgb, currentColor 25%, transparent);
        background: color-mix(in srgb, currentColor 6%, transparent);
      }
    </style>
  </head>
  <body>
    <header class="shell">
      <h1>factory5</h1>
      <nav class="nav-inline">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              aria-current={Astro.url.pathname === link.href ? 'page' : undefined}
            >
              {link.label}
            </a>
          ))
        }
      </nav>
      <div class="header-actions">
        <span class="status-pip" id="status-pip" data-status="reconnecting" aria-live="polite">
          <span class="pip-dot" aria-hidden="true"></span>
          <span class="pip-label">Connecting…</span>
        </span>
        <button type="button" class="btn-text btn-logout" data-logout>Sign out</button>
      </div>
      <details class="nav-drawer">
        <summary aria-label="Navigation">
          <span class="hamburger" aria-hidden="true">
            <span></span><span></span><span></span>
          </span>
        </summary>
        <nav>
          {
            navLinks.map((link) => (
              <a
                href={link.href}
                aria-current={Astro.url.pathname === link.href ? 'page' : undefined}
              >
                {link.label}
              </a>
            ))
          }
          <button type="button" class="btn-text drawer-logout" data-logout>
            Sign out
          </button>
        </nav>
      </details>
    </header>
    <main class="shell">
      <div class="logged-out-banner alert alert--info" id="logged-out-banner" hidden>
        Signed out — reopen the URL logged by factoryd to sign in.
      </div>
      <h2>{title}</h2>
      <slot />
    </main>
    <script>
      import {
        apiFetch,
        ApiError,
        captureTokenFromUrl,
        clearToken,
        getToken,
        NoTokenError,
      } from '../lib/api';

      // Idempotent — page-level scripts also call this; whichever runs first wins.
      captureTokenFromUrl();

      // Logged-out banner: show on `?logged-out=1`, then strip the param so a
      // refresh doesn't keep replaying the banner.
      {
        const params = new URLSearchParams(window.location.search);
        if (params.get('logged-out') === '1') {
          const banner = document.getElementById('logged-out-banner');
          if (banner !== null) banner.hidden = false;
          params.delete('logged-out');
          const query = params.toString();
          const newUrl =
            window.location.pathname +
            (query.length > 0 ? `?${query}` : '') +
            window.location.hash;
          window.history.replaceState({}, '', newUrl);
        }
      }

      // Logout — single handler wired to every [data-logout] button (desktop
      // header + mobile drawer share the click target).
      for (const btn of document.querySelectorAll<HTMLButtonElement>('[data-logout]')) {
        btn.addEventListener('click', () => {
          clearToken();
          window.location.href = '/app/?logged-out=1';
        });
      }

      // Connection-status heartbeat — poll /api/v1/status every 30s.
      // 0 failures → green Connected; 1-2 → amber Reconnecting;
      // 3+ consecutive → red Disconnected. No-token jumps straight to red
      // labelled "Signed out" so the post-logout state reads honestly.
      const POLL_INTERVAL_MS = 30_000;
      const FAILURE_THRESHOLD = 3;

      type PipState = 'connected' | 'reconnecting' | 'disconnected';

      let consecutiveFailures = 0;

      const setStatus = (state: PipState, label: string, hover?: string): void => {
        const pip = document.getElementById('status-pip');
        if (pip === null) return;
        pip.dataset.status = state;
        pip.title = hover ?? label;
        const labelEl = pip.querySelector('.pip-label');
        if (labelEl !== null) labelEl.textContent = label;
      };

      const tick = async (): Promise<void> => {
        if (getToken() === null) {
          consecutiveFailures = FAILURE_THRESHOLD;
          setStatus('disconnected', 'Signed out');
          return;
        }
        try {
          await apiFetch('/api/v1/status');
          consecutiveFailures = 0;
          setStatus('connected', 'Connected');
        } catch (err) {
          if (err instanceof NoTokenError) {
            setStatus('disconnected', 'Signed out');
            return;
          }
          // 401 means the stored token is stale (commonly: daemon restart
          // rotated the token, or the operator was signed out elsewhere).
          // Polling won't recover this — short-circuit to a label that tells
          // the operator what to do instead of cycling through "Reconnecting".
          if (err instanceof ApiError && err.status === 401) {
            consecutiveFailures = FAILURE_THRESHOLD;
            setStatus(
              'disconnected',
              'Session expired',
              'Daemon restarted — run `factory ui-token` for a fresh URL (or paste a new URL from the daemon stdout).',
            );
            return;
          }
          consecutiveFailures++;
          if (consecutiveFailures >= FAILURE_THRESHOLD) {
            setStatus('disconnected', 'Disconnected');
          } else {
            setStatus('reconnecting', 'Reconnecting…');
          }
        }
      };

      void tick();
      window.setInterval(() => void tick(), POLL_INTERVAL_MS);
    </script>
  </body>
</html>
