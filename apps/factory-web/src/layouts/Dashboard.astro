---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — factory5</title>
    <style>
      :root {
        color-scheme: light dark;
        font-family:
          system-ui,
          -apple-system,
          Segoe UI,
          Roboto,
          sans-serif;
      }
      body {
        margin: 0;
        padding: 0;
      }
      header.shell {
        padding: 0.75rem 1.5rem;
        border-bottom: 1px solid color-mix(in srgb, currentColor 15%, transparent);
      }
      header.shell h1 {
        margin: 0;
        font-size: 1rem;
        font-weight: 600;
      }
      main.shell {
        padding: 1.5rem;
        max-width: 64rem;
        margin: 0 auto;
      }
      pre {
        padding: 0.75rem 1rem;
        background: color-mix(in srgb, currentColor 6%, transparent);
        border-radius: 4px;
        overflow-x: auto;
      }
    </style>
  </head>
  <body>
    <header class="shell">
      <h1>factory5 — {title}</h1>
    </header>
    <main class="shell">
      <slot />
    </main>
  </body>
</html>
