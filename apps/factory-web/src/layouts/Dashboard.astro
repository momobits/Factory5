---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
}
const { title } = Astro.props;

interface NavLink {
  href: string;
  label: string;
}
const navLinks: NavLink[] = [
  { href: '/app/', label: 'Overview' },
  { href: '/app/projects/', label: 'Projects' },
  { href: '/app/build', label: 'Build' },
  { href: '/app/directives/', label: 'Directives' },
  { href: '/app/questions/', label: 'Questions' },
  { href: '/app/spend/', label: 'Spend' },
  { href: '/app/findings/', label: 'Findings' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — factory5</title>
    <ClientRouter />
    <style>
      :root {
        color-scheme: light dark;
        font-family:
          system-ui,
          -apple-system,
          Segoe UI,
          Roboto,
          sans-serif;
      }
      body {
        margin: 0;
        padding: 0;
      }
      header.shell {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding: 0.75rem 1.5rem;
        border-bottom: 1px solid color-mix(in srgb, currentColor 15%, transparent);
      }
      header.shell h1 {
        margin: 0;
        font-size: 1rem;
        font-weight: 600;
      }
      header.shell nav {
        display: flex;
        gap: 1rem;
      }
      header.shell nav a {
        color: inherit;
        text-decoration: none;
        font-size: 0.9rem;
        padding: 0.25rem 0.5rem;
        border-radius: 3px;
      }
      header.shell nav a[aria-current='page'],
      header.shell nav a:hover {
        background: color-mix(in srgb, currentColor 10%, transparent);
      }
      main.shell {
        padding: 1.5rem;
        max-width: 72rem;
        margin: 0 auto;
      }
      main.shell h2 {
        margin-top: 0;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
      }
      th,
      td {
        text-align: left;
        padding: 0.4rem 0.6rem;
        border-bottom: 1px solid color-mix(in srgb, currentColor 10%, transparent);
      }
      th {
        font-weight: 600;
        background: color-mix(in srgb, currentColor 4%, transparent);
      }
      td.num {
        text-align: right;
        font-variant-numeric: tabular-nums;
      }
      pre {
        padding: 0.75rem 1rem;
        background: color-mix(in srgb, currentColor 6%, transparent);
        border-radius: 4px;
        overflow-x: auto;
      }
      .empty {
        color: color-mix(in srgb, currentColor 60%, transparent);
        font-style: italic;
      }
      .err {
        color: #c24;
      }
      .filter-form {
        display: flex;
        gap: 0.5rem;
        align-items: center;
        margin-bottom: 1rem;
        flex-wrap: wrap;
      }
      .filter-form label {
        font-size: 0.85rem;
      }
      .cards {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(12rem, 1fr));
        gap: 1rem;
      }
      .card {
        padding: 1rem;
        border: 1px solid color-mix(in srgb, currentColor 15%, transparent);
        border-radius: 6px;
      }
      .card h3 {
        margin: 0 0 0.25rem 0;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: color-mix(in srgb, currentColor 70%, transparent);
      }
      .card .value {
        font-size: 1.75rem;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
      }
      a.link {
        color: inherit;
      }

      /* Form primitives — added in 11.5 (ADR 0027). Uses the same
         color-mix(currentColor) palette as the rest of the dashboard so
         every input/button auto-adapts to light/dark via color-scheme. */
      form.form {
        display: grid;
        gap: 1rem;
        max-width: 36rem;
        margin-top: 1rem;
      }
      form.form.wide {
        max-width: none;
      }
      .form-field {
        display: grid;
        gap: 0.25rem;
      }
      .form-field label {
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.01em;
      }
      .form-field input,
      .form-field select,
      .form-field textarea {
        font: inherit;
        font-size: 0.9rem;
        padding: 0.45rem 0.6rem;
        border: 1px solid color-mix(in srgb, currentColor 20%, transparent);
        border-radius: 4px;
        background: color-mix(in srgb, currentColor 3%, transparent);
        color: inherit;
        color-scheme: inherit;
      }
      .form-field input[type='number'] {
        font-variant-numeric: tabular-nums;
      }
      .form-field input:focus,
      .form-field select:focus,
      .form-field textarea:focus {
        outline: 2px solid color-mix(in srgb, currentColor 30%, transparent);
        outline-offset: -1px;
        background: color-mix(in srgb, currentColor 5%, transparent);
      }
      .form-field textarea {
        min-height: 7rem;
        resize: vertical;
        font-family: ui-monospace, SFMono-Regular, Consolas, 'Liberation Mono', Menlo, monospace;
        line-height: 1.45;
      }
      .form-field .hint {
        font-size: 0.8rem;
        color: color-mix(in srgb, currentColor 60%, transparent);
      }
      .form-row {
        display: grid;
        gap: 1rem;
        grid-template-columns: 1fr 1fr;
      }
      .form-actions {
        display: flex;
        gap: 0.75rem;
        align-items: center;
        flex-wrap: wrap;
      }
      .btn {
        font: inherit;
        font-size: 0.9rem;
        padding: 0.45rem 1rem;
        border: 1px solid color-mix(in srgb, currentColor 25%, transparent);
        border-radius: 4px;
        background: color-mix(in srgb, currentColor 4%, transparent);
        color: inherit;
        cursor: pointer;
      }
      .btn:hover:not(:disabled) {
        background: color-mix(in srgb, currentColor 10%, transparent);
      }
      .btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
      }
      .btn-primary {
        background: color-mix(in srgb, currentColor 85%, transparent);
        color: Canvas;
        border-color: transparent;
      }
      .btn-primary:hover:not(:disabled) {
        background: color-mix(in srgb, currentColor 95%, transparent);
      }
      .btn-danger {
        border-color: color-mix(in srgb, #c24 50%, transparent);
        color: #c24;
      }
      .btn-danger:hover:not(:disabled) {
        background: color-mix(in srgb, #c24 8%, transparent);
      }
      .alert {
        padding: 0.75rem 1rem;
        border-radius: 4px;
        border: 1px solid color-mix(in srgb, currentColor 18%, transparent);
        background: color-mix(in srgb, currentColor 5%, transparent);
        font-size: 0.9rem;
        max-width: 36rem;
      }
      .alert h4 {
        margin: 0 0 0.25rem 0;
        font-size: 0.95rem;
      }
      .alert p {
        margin: 0.25rem 0;
      }
      .alert pre {
        margin: 0.5rem 0 0 0;
        padding: 0.5rem 0.75rem;
        font-size: 0.85rem;
      }
      .alert--conflict {
        border-color: color-mix(in srgb, #c24 50%, transparent);
        background: color-mix(in srgb, #c24 8%, transparent);
      }
      .alert--success {
        border-color: color-mix(in srgb, #2a8 55%, transparent);
        background: color-mix(in srgb, #2a8 8%, transparent);
      }
      .alert--info {
        border-color: color-mix(in srgb, currentColor 25%, transparent);
        background: color-mix(in srgb, currentColor 6%, transparent);
      }
    </style>
  </head>
  <body>
    <header class="shell">
      <h1>factory5</h1>
      <nav>
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              aria-current={Astro.url.pathname === link.href ? 'page' : undefined}
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </header>
    <main class="shell">
      <h2>{title}</h2>
      <slot />
    </main>
  </body>
</html>
