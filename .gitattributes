# Line-ending policy for factory5.
#
# Treat every file as text by default and store it with LF in the repository,
# checking it out with LF on every platform. This makes the Prettier gate
# (`.prettierrc` -> "endOfLine": "lf") deterministic on Windows checkouts,
# where `core.autocrlf=true` would otherwise leave CRLF in the working tree
# and make `prettier --check` report every file as changed.
#
# `text=auto` keeps git's binary auto-detection: files that look binary
# (e.g. apps/factory-web/src/pages/chat.astro) are left untouched.
* text=auto eol=lf

# Binary assets — never apply text or EOL filters. None are tracked today
# (images/fonts/db live under gitignored paths), but these rules prevent
# corruption if any are committed later.
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.webp    binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary
*.otf     binary
*.pdf     binary
*.zip     binary
*.gz      binary
*.wasm    binary
*.node    binary
*.db      binary
*.sqlite  binary
*.sqlite3 binary
