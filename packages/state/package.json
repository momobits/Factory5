{
  "name": "@factory5/state",
  "version": "0.0.1",
  "private": true,
  "description": "SQLite (better-sqlite3) wrapper, migrations, and typed CRUD for factory5 runtime state",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "dev": "tsup src/index.ts --format esm --dts --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@factory5/core": "workspace:*",
    "@factory5/logger": "workspace:*",
    "better-sqlite3": "^11.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "tsup": "^8.2.0",
    "vitest": "^2.0.0"
  }
}
