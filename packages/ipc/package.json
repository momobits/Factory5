{
  "name": "@factory5/ipc",
  "version": "0.0.1",
  "private": true,
  "description": "HTTP contracts (Zod) and typed client for daemon ↔ brain communication",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./sse": {
      "types": "./dist/sse.d.ts",
      "development": "./src/sse.ts",
      "import": "./dist/sse.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/sse.ts --format esm --dts --sourcemap --clean",
    "dev": "tsup src/index.ts src/sse.ts --format esm --dts --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@factory5/core": "workspace:*",
    "@factory5/logger": "workspace:*",
    "undici": "^6.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "tsup": "^8.2.0",
    "vitest": "^2.0.0"
  }
}
