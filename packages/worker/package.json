{
  "name": "@factory5/worker",
  "version": "0.0.1",
  "private": true,
  "description": "Per-task subprocess: allocate worktree, spawn coding-agent CLI, stream output, persist results",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "dev": "tsup src/index.ts --format esm --dts --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@factory5/core": "workspace:*",
    "@factory5/logger": "workspace:*",
    "@factory5/providers": "workspace:*",
    "@factory5/state": "workspace:*",
    "@factory5/wiki": "workspace:*",
    "@factory5/worker-mcp": "workspace:*",
    "@factory5/worker-sandbox": "workspace:*",
    "simple-git": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "tsup": "^8.2.0",
    "vitest": "^2.0.0"
  }
}
