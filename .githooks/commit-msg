#!/usr/bin/env bash
# Control framework -- commit-msg hook
#
# Enforces the canonical commit shape from CONTROL_COMMIT_FORMAT:
#
#   <type>(<phase>.<step>): <subject>
#
# Skips merge / revert / fixup commits (git defines those shapes).
#
# Bypass: git commit --no-verify (use sparingly; see PROJECT_PROTOCOL.md).
# Marker for npx control-workflow uninstall: control:commit-msg

set -euo pipefail

MSG_FILE="$1"
SUBJECT="$(head -n1 "$MSG_FILE")"

# --- bypass cases (git's own conventions) ---
case "$SUBJECT" in
    "Merge "*|"Revert "*|"fixup! "*|"squash! "*|"amend! "*) exit 0 ;;
esac

if git rev-parse --verify --quiet MERGE_HEAD >/dev/null 2>&1; then
    exit 0
fi

# --- types from .control/config.sh (defensive default if missing) ---
CONFIG_FILE="$(git rev-parse --show-toplevel)/.control/config.sh"
if [ -f "$CONFIG_FILE" ]; then
    # shellcheck disable=SC1090
    . "$CONFIG_FILE"
fi
TYPES="${CONTROL_COMMIT_TYPES:-feat fix test docs refactor chore}"
TYPES_RE="$(printf '%s|' $TYPES | sed 's/|$//')"

# --- shape regex ---
# Parens allowlist (hardcoded; documented in PROJECT_PROTOCOL.md § Commit-msg contract):
#   [0-9]+(\.[0-9]+[a-z]?)?  -- phase / step / step with letter suffix (3 / 3.4 / 3.4b)
#   phase-[a-z0-9.-]+        -- phase-close commits (phase-3 / phase-3-v1.4.0)
#   adr | issues | state     -- per /new-adr, /close-issue, /session-end
#   spec                     -- per /spec-amend
#   install                  -- the installer's own commit (control-workflow init)
#   [A-Z](\.[0-9]+[a-z]?)?   -- redesign group/ID (A / A.1 / C.5a) — used by redesign type
#   reconcile(\.[0-9]+[a-z]?)? -- v1.4-to-v2.0 reconciliation work
PARENS_RE='([0-9]+(\.[0-9]+[a-z]?)?|phase-[a-z0-9.-]+|adr|issues|state|spec|install|[A-Z](\.[0-9]+[a-z]?)?|reconcile(\.[0-9]+[a-z]?)?)'
SHAPE_RE="^($TYPES_RE)\\($PARENS_RE\\): .{3,}$"

if [[ "$SUBJECT" =~ $SHAPE_RE ]]; then
    exit 0
fi

cat >&2 <<EOF
[control:commit-msg] Rejected: commit subject does not match
   <type>(<phase>.<step>): <subject>

Got: $SUBJECT

Allowed types: $TYPES
Examples:
   feat(3.4): add users table migration
   fix(2.1): ISSUE-12 migration deadlock
   docs(adr): ADR-0007 migration policy
   chore(phase-3): close phase 3, kick off phase 4
   docs(state): session end for step 3.4
   docs(issues): open ISSUE-2026-04-27-flakiness
   docs(spec): add artifact 2026-04-27-evolution -- migrate to v2 schema
   chore(install): install Control framework v1.3.0

See .control/PROJECT_PROTOCOL.md § Commit-msg contract.

To bypass legitimately (vendor-import / conflict-resolved squash only):
   git commit --no-verify
EOF
exit 1
