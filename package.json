{
  "name": "factory5",
  "version": "0.0.1",
  "private": true,
  "description": "Autonomous software builder — multi-channel, multi-provider, verification-first",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=4 run build",
    "dev": "pnpm -r --parallel run dev",
    "test": "pnpm -r run test",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r exec rimraf dist .turbo node_modules/.cache",
    "factory": "tsx apps/factory/src/main.ts",
    "factoryd": "tsx apps/factoryd/src/main.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.2.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
